{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CommandTranscript",
  "type": "object",
  "required": ["phase", "timestamp_utc", "commands"],
  "properties": {
    "phase": {"type": "string"},
    "timestamp_utc": {"type": "string", "format": "date-time"},
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command_id", "command_string", "exit_code", "verdict"],
        "properties": {
          "command_id": {"type": "string"},
          "command_string": {"type": "string"},
          "working_directory": {"type": "string"},
          "exit_code": {"type": "integer"},
          "duration_ms": {"type": "integer"},
          "stdout_path": {"type": "string"},
          "stderr_path": {"type": "string"},
          "tests_discovered": {"type": "integer"},
          "tests_run": {"type": "integer"},
          "verdict": {"type": "string", "enum": ["PASS", "FAIL", "BLOCKED", "UNKNOWN", "NOT_APPLICABLE"]},
          "evidence_artifact": {"type": "string"}
        }
      }
    }
  }
}
