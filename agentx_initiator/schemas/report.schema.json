{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentx-init/schemas/report.schema.json",
  "title": "Report Schema",
  "type": "object",
  "properties": {
    "schema_version": {"type": "string"},
    "report_id": {"type": "string"},
    "timestamp": {"type": "string"},
    "report_type": {"type": "string", "enum": ["STATUS_REPORT", "ARCHITECTURE_REPORT"]},
    "status": {"type": "string", "enum": ["PASS", "PARTIAL", "FAIL", "BLOCKED"]},
    "title": {"type": "string"},
    "source_artifact_refs": {"type": "array", "items": {"type": "string"}},
    "template_id": {"type": "string"},
    "sections": {"type": "array", "items": {"$ref": "report_section.schema.json"}},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "required": ["schema_version", "report_id", "timestamp", "report_type", "status", "title", "sections"]
}
