{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "memory_manifest.schema.json",
  "owner_component": "MemoryStore",
  "artifact_type": "memory_manifest",
  "type": "object",
  "required": ["schema_version", "manifest_id", "timestamp", "record_count"],
  "properties": {
    "schema_version": {"type": "string"},
    "manifest_id": {"type": "string"},
    "timestamp": {"type": "string"},
    "record_count": {"type": "integer"},
    "latest_snapshot": {"type": "string"},
    "latest_index": {"type": "string"},
    "categories": {"type": "array", "items": {"type": "string"}},
    "schema_versions": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
