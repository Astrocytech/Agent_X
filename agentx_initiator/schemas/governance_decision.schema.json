{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "governance_decision.schema.json",
  "owner_component": "GovernanceEngine",
  "artifact_type": "governance_decision",
  "type": "object",
  "required": ["schema_version", "decision_id", "request_id", "timestamp", "decision", "decision_reason", "applied_rule_ids", "evidence_ids", "source_component", "status"],
  "properties": {
    "schema_version": {"type": "string"},
    "decision_id": {"type": "string"},
    "request_id": {"type": "string"},
    "timestamp": {"type": "string"},
    "decision": {"type": "string", "enum": ["ALLOW", "WARN", "BLOCK"]},
    "decision_reason": {"type": "string"},
    "applied_rule_ids": {"type": "array", "items": {"type": "string"}},
    "evidence_ids": {"type": "array", "items": {"type": "string"}},
    "violations": {"type": "array"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "required_approvals": {"type": "array", "items": {"type": "string"}},
    "source_component": {"type": "string"},
    "status": {"type": "string", "enum": ["PASS", "FAIL", "BLOCKED"]}
  },
  "additionalProperties": false
}
