{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentx-init/schemas/architecture_report.schema.json",
  "title": "Architecture Report Schema",
  "type": "object",
  "properties": {
    "layers": {"type": "array"},
    "layer_count": {"type": "integer"},
    "valid_layer_structure": {"type": "boolean"},
    "l0_independent": {"type": "boolean"},
    "l1_separated": {"type": "boolean"},
    "l2_contains_active_runtime": {"type": "boolean"},
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "layer": {"type": "string"},
          "concern": {"type": "string"},
          "severity": {"type": "string"}
        }
      }
    }
  },
  "required": ["layers", "layer_count", "valid_layer_structure"]
}
