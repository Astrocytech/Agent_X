{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentx-init/schemas/validation_report.schema.json",
  "title": "Validation Report Schema",
  "type": "object",
  "properties": {
    "validation_results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "command": {"type": "string"},
          "passed": {"type": "boolean"},
          "returncode": {"type": "integer"},
          "stdout": {"type": "string"},
          "stderr": {"type": "string"}
        },
        "required": ["command", "passed"]
      }
    },
    "passed": {"type": "integer"},
    "failed": {"type": "integer"}
  },
  "required": ["validation_results", "passed", "failed"]
}
