{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "validation_report.schema.json",
  "owner_component": "ValidationRunner",
  "artifact_type": "validation_report",
  "type": "object",
  "required": ["schema_version", "report_id", "timestamp", "source_component", "status", "allowlist_entries", "runs", "manifest"],
  "properties": {
    "schema_version": {"type": "string"},
    "report_id": {"type": "string"},
    "timestamp": {"type": "string"},
    "source_component": {"type": "string"},
    "status": {"type": "string", "enum": ["PASS", "FAIL", "PARTIAL", "BLOCKED"]},
    "allowlist_entries": {"type": "array", "items": {"type": "object"}},
    "runs": {"type": "array", "items": {"type": "object"}},
    "manifest": {"type": "object"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
