{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentx-init/schemas/protected_path_map.schema.json",
  "title": "Protected Path Map Schema",
  "type": "object",
  "properties": {
    "schema_version": {"type": "string"},
    "entries": {"type": "array", "items": {
      "type": "object",
      "properties": {
        "path": {"type": "string"},
        "protection_level": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
        "layer": {"type": "string"},
        "reason": {"type": "string"}
      },
      "required": ["path", "protection_level", "layer"]
    }},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "required": ["schema_version", "entries"]
}
