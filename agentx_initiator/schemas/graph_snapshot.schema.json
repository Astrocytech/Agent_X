{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Graph Snapshot Schema",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "generated_at": {"type": "string"},
        "type": {"type": "string"}
      },
      "required": ["generated_at", "type"]
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "label": {"type": "string"}
        },
        "required": ["id", "type", "label"]
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": {"type": "string"},
          "target": {"type": "string"},
          "relation": {"type": "string"}
        },
        "required": ["source", "target", "relation"]
      }
    }
  },
  "required": ["metadata", "nodes", "edges"]
}
