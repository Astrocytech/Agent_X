{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentx-init/schemas/graph_query_result.schema.json",
  "title": "Graph Query Result",
  "description": "Result of a Knowledge Graph query",
  "type": "object",
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "schema_id": { "type": "string", "const": "graph_query_result.schema.json" },
    "owner_component": { "type": "string", "const": "AGENTX_KNOWLEDGE_GRAPH" },
    "artifact_type": { "type": "string", "const": "graph_query_result" },
    "query_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string" },
    "query": { "type": "object" },
    "node_results": { "type": "array", "items": { "type": "object" } },
    "edge_results": { "type": "array", "items": { "type": "object" } },
    "result_count": { "type": "integer", "minimum": 0 },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  },
  "required": [
    "schema_version", "schema_id", "owner_component", "artifact_type",
    "query_id", "timestamp", "query", "node_results", "edge_results",
    "result_count", "warnings", "errors"
  ],
  "additionalProperties": false
}
