{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Graph Query Result Schema",
  "type": "object",
  "properties": {
    "query": {"type": "string"},
    "nodes": {
      "type": "array",
      "items": {"$ref": "graph_node.schema.json"}
    },
    "edges": {
      "type": "array",
      "items": {"$ref": "graph_edge.schema.json"}
    },
    "total_count": {"type": "integer"}
  },
  "required": ["query", "nodes", "edges"]
}
