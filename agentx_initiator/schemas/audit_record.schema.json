{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentx-init/schemas/audit_record.schema.json",
  "title": "Audit Record Schema",
  "type": "object",
  "properties": {
    "schema_version": {"type": "string"},
    "record_id": {"type": "string"},
    "timestamp": {"type": "string"},
    "event": {"$ref": "audit_event.schema.json"},
    "evidence": {"type": "array", "items": {"$ref": "audit_evidence.schema.json"}},
    "integrity_hash": {"type": "string"}
  },
  "required": ["schema_version", "record_id", "timestamp", "event"]
}
