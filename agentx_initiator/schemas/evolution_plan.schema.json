{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "evolution_plan.schema.json",
  "owner_component": "EvolutionPlanner",
  "artifact_type": "evolution_plan",
  "type": "object",
  "required": ["schema_version", "plan_id", "timestamp", "source_component", "status", "steps", "manifest"],
  "properties": {
    "schema_version": {"type": "string"},
    "plan_id": {"type": "string"},
    "timestamp": {"type": "string"},
    "source_component": {"type": "string"},
    "status": {"type": "string", "enum": ["DRAFT", "IN_PROGRESS", "COMPLETED", "BLOCKED"]},
    "steps": {"type": "array", "items": {"$ref": "#/definitions/EvolutionStep"}},
    "manifest": {"type": "object"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false,
  "definitions": {
    "EvolutionStep": {
      "type": "object",
      "required": ["step_id", "priority", "category", "action", "detail", "dependencies", "status"],
      "properties": {
        "step_id": {"type": "string"},
        "priority": {"type": "string", "enum": ["P0", "P1", "P2", "P3"]},
        "category": {"type": "string", "enum": ["GOVERNANCE", "STRUCTURE", "VALIDATION", "TESTING", "SCHEMA", "SPECIALIZATION", "INTEGRATION", "UNKNOWN"]},
        "action": {"type": "string"},
        "detail": {"type": "string"},
        "dependencies": {"type": "array", "items": {"type": "string"}},
        "status": {"type": "string"}
      },
      "additionalProperties": false
    }
  }
}
