{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evolution Plan Schema",
  "type": "object",
  "properties": {
    "plan_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "priority": {"type": "integer"},
          "category": {"type": "string"},
          "action": {"type": "string"},
          "detail": {"type": "string"}
        },
        "required": ["priority", "category", "action"]
      }
    },
    "count": {"type": "integer"},
    "generated_at": {"type": "string"}
  },
  "required": ["plan_items", "count"]
}
