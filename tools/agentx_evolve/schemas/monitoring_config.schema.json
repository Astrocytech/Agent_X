{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "monitoring_config.schema.json",
  "title": "Monitoring Config",
  "description": "Schema for the monitoring configuration within the Monitoring Observability Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "enabled",
    "monitoring_root",
    "retention_days",
    "component"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "monitoring_config.schema.json",
      "description": "Unique schema identifier"
    },
    "enabled": {
      "type": "boolean",
      "description": "Whether monitoring is enabled"
    },
    "monitoring_root": {
      "type": "string",
      "description": "Root directory for monitoring data"
    },
    "retention_days": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of days to retain monitoring data"
    },
    "max_events": {
      "type": "integer",
      "minimum": 0,
      "description": "Maximum number of events to retain"
    },
    "max_metrics": {
      "type": "integer",
      "minimum": 0,
      "description": "Maximum number of metrics to retain"
    },
    "health_check_interval_seconds": {
      "type": "integer",
      "minimum": 0,
      "description": "Interval between health checks in seconds"
    },
    "alert_evaluation_interval_seconds": {
      "type": "integer",
      "minimum": 0,
      "description": "Interval between alert evaluations in seconds"
    },
    "trace_enabled": {
      "type": "boolean",
      "description": "Whether distributed tracing is enabled"
    },
    "metric_collection_enabled": {
      "type": "boolean",
      "description": "Whether metric collection is enabled"
    },
    "redact_secrets": {
      "type": "boolean",
      "description": "Whether to redact secrets in monitoring data"
    },
    "redacted_keys": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of keys whose values should be redacted"
    },
    "component": {
      "type": "string",
      "minLength": 1,
      "description": "Component name for this configuration"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
