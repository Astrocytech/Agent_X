{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "local_model_availability.schema.json",
  "title": "Local Model Availability Decision",
  "type": "object",
  "required": ["decision_id", "timestamp", "model_id", "availability"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "local_model_availability.schema.json"},
    "decision_id": {"type": "string"},
    "timestamp": {"type": "string"},
    "model_id": {"type": "string"},
    "availability": {"type": "string", "enum": ["AVAILABLE", "MISSING", "BLOCKED"]},
    "model_path": {"type": ["string", "null"]},
    "path_allowed": {"type": "boolean"},
    "file_present": {"type": "boolean"},
    "profile_repository_hash": {"type": "string"},
    "failure_class": {"type": ["string", "null"]},
    "reason": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
