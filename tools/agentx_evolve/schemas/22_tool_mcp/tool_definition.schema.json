{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "tool_definition.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "tool_name",
    "description",
    "owner_component",
    "trust_tier",
    "input_schema_id",
    "output_schema_id",
    "allowed_roles",
    "requested_effects",
    "requires_sandbox_check",
    "requires_capability_policy",
    "enabled",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "tool_name": { "type": "string" },
    "description": { "type": "string" },
    "owner_component": { "type": "string" },
    "trust_tier": { "type": "string" },
    "input_schema_id": { "type": "string" },
    "output_schema_id": { "type": "string" },
    "allowed_roles": { "type": "array", "items": { "type": "string" } },
    "requested_effects": { "type": "array", "items": { "type": "string" } },
    "requires_sandbox_check": { "type": "boolean" },
    "requires_capability_policy": { "type": "boolean" },
    "requires_governance": { "type": "boolean" },
    "requires_human_approval": { "type": "boolean" },
    "requires_dry_run": { "type": "boolean" },
    "writes_source": { "type": "boolean" },
    "writes_runtime_state": { "type": "boolean" },
    "runs_subprocess": { "type": "boolean" },
    "uses_network": { "type": "boolean" },
    "allowlisted": { "type": "boolean" },
    "enabled": { "type": "boolean" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
