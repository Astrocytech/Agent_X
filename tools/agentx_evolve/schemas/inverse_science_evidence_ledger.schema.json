{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentx.example/schemas/inverse_science_evidence_ledger",
  "title": "Inverse Science Evidence Ledger Entry",
  "type": "object",
  "required": [
    "entry_id",
    "observation_id",
    "candidate_id",
    "plan_id",
    "schema_version",
    "claim_tested",
    "expected_result",
    "observed_result",
    "evidence_class",
    "interpretation",
    "uncertainty_remaining",
    "claim_status",
    "affects_future_ranking",
    "created_at_utc"
  ],
  "properties": {
    "entry_id": {
      "type": "string",
      "pattern": "^INVSCI-EVID-[A-Z0-9-]+$"
    },
    "observation_id": {
      "type": "string",
      "pattern": "^INVSCI-OBS-[A-Z0-9-]+$"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^INVSCI-CAND-[A-Z0-9-]+$"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^INVSCI-PLAN-[A-Z0-9-]+$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "claim_tested": {
      "type": "string"
    },
    "expected_result": {
      "type": "string"
    },
    "observed_result": {
      "type": "string"
    },
    "evidence_class": {
      "type": "string",
      "enum": [
        "unsupported_claim",
        "inspection_evidence",
        "test_evidence",
        "comparative_evidence",
        "replicated_evidence",
        "negative_evidence"
      ]
    },
    "interpretation": {
      "type": "string"
    },
    "uncertainty_remaining": {
      "type": "string"
    },
    "claim_status": {
      "type": "string",
      "enum": ["supported", "refuted", "uncertain", "inconclusive"]
    },
    "affects_future_ranking": {
      "type": "boolean"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  },
  "if": {
    "properties": { "evidence_class": { "const": "unsupported_claim" } },
    "required": ["evidence_class"]
  },
  "then": {
    "properties": { "claim_status": { "not": { "const": "supported" } } }
  },
  "additionalProperties": false
}
