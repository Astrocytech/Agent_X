{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "schema_id": "prompt_completion_record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "component_id", "component_name",
    "status", "validated_commit", "validated_at",
    "canonical_subdirectory", "canonical_schema_subdirectory",
    "canonical_test_subdirectory", "runtime_artifact_root",
    "basis_documents", "final_decision"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "prompt_completion_record.schema.json"},
    "component_id": {"type": "string"},
    "component_name": {"type": "string"},
    "status": {"type": "string"},
    "validated_commit": {"type": "string"},
    "validated_at": {"type": "string"},
    "canonical_subdirectory": {"type": "string"},
    "canonical_schema_subdirectory": {"type": "string"},
    "canonical_test_subdirectory": {"type": "string"},
    "runtime_artifact_root": {"type": "string"},
    "basis_documents": {"type": "array", "items": {"type": "string"}},
    "commands_run": {"type": "array", "items": {"type": "string"}},
    "files_created_or_changed": {"type": "array", "items": {"type": "string"}},
    "schemas_created_or_changed": {"type": "array", "items": {"type": "string"}},
    "tests_created_or_changed": {"type": "array", "items": {"type": "string"}},
    "validated_capabilities": {"type": "array", "items": {"type": "string"}},
    "prompt_contracts_verified": {"type": "array", "items": {"type": "string"}},
    "prompt_versions_verified": {"type": "array", "items": {"type": "string"}},
    "prompt_registry_verified": {"type": "array", "items": {"type": "string"}},
    "prompt_compatibility_verified": {"type": "array", "items": {"type": "string"}},
    "prompt_migrations_verified": {"type": "array", "items": {"type": "string"}},
    "prompt_runtime_bindings_verified": {"type": "array", "items": {"type": "string"}},
    "prompt_safety_verified": {"type": "array", "items": {"type": "string"}},
    "prompt_provenance_verified": {"type": "array", "items": {"type": "string"}},
    "prompt_evidence_verified": {"type": "array", "items": {"type": "string"}},
    "policy_integration_verified": {"type": "array", "items": {"type": "string"}},
    "tool_adapter_integration_verified": {"type": "array", "items": {"type": "string"}},
    "model_adapter_integration_verified": {"type": "array", "items": {"type": "string"}},
    "context_builder_integration_verified": {"type": "array", "items": {"type": "string"}},
    "llm_worker_integration_verified": {"type": "array", "items": {"type": "string"}},
    "negative_tests_verified": {"type": "array", "items": {"type": "string"}},
    "evidence_manifest_path": {"type": "string"},
    "evidence_manifest_sha256": {"type": "string"},
    "completion_record_sha256": {"type": "string"},
    "deviations_from_contract": {"type": "array", "items": {"type": "string"}},
    "unresolved_risks": {"type": "array", "items": {"type": "string"}},
    "implementation_score": {"type": "number"},
    "final_decision": {"type": "string"}
  }
}
