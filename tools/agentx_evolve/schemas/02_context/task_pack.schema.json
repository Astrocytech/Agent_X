{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "task_pack.schema.json",
  "title": "TaskPack",
  "type": "object",
  "required": ["schema_version", "schema_id", "task_pack_id", "created_at", "status", "warnings", "errors"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"type": "string", "pattern": "^task_pack\\.schema\\.json$"},
    "task_pack_id": {"type": "string"},
    "created_at": {"type": "string"},
    "source_component": {"type": "string"},
    "task_input": {"type": "object"},
    "context_pack": {"type": "object"},
    "prompt_contract_id": {"type": "string"},
    "model_profile_id": {"type": "string"},
    "runtime_profile_id": {"type": "string"},
    "status": {"type": "string", "enum": ["DRAFT", "READY", "BLOCKED", "INVALID"]},
    "failure_class": {"type": "string"},
    "allowed_tools": {"type": "array", "items": {"type": "string"}},
    "blocked_tools": {"type": "array", "items": {"type": "string"}},
    "final_instructions": {"type": "array", "items": {"type": "string"}},
    "required_outputs": {"type": "array", "items": {"type": "string"}},
    "forbidden_actions": {"type": "array", "items": {"type": "string"}},
    "artifact_refs": {"type": "array", "items": {"type": "string"}},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
