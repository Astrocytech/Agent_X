{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "context_pack_evidence.schema.json",
  "title": "ContextPackEvidence",
  "type": "object",
  "required": ["schema_version", "schema_id", "component_id", "validated_commit", "validated_at", "warnings", "errors"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"type": "string"},
    "component_id": {"type": "string"},
    "validated_commit": {"type": "string"},
    "validated_at": {"type": "string"},
    "context_pack_id": {"type": "string"},
    "context_pack_hash": {"type": "string"},
    "task_pack_id": {"type": "string"},
    "task_pack_hash": {"type": "string"},
    "evidence_files": {"type": "array", "items": {"type": "string"}},
    "evidence_file_hashes": {"type": "array", "items": {"type": "object", "properties": {"path": {"type": "string"}, "sha256": {"type": "string"}}}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
