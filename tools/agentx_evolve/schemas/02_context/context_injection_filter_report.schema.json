{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "context_injection_filter_report.schema.json",
  "title": "ContextInjectionFilterReport",
  "type": "object",
  "required": ["schema_version", "schema_id", "context_item_id", "risk_level", "decision", "warnings", "errors"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"type": "string"},
    "context_item_id": {"type": "string"},
    "risk_level": {"type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]},
    "patterns_detected": {"type": "array", "items": {"type": "string"}},
    "decision": {"type": "string"},
    "reason": {"type": "string"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
