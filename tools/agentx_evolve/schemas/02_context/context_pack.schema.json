{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "context_pack.schema.json",
  "title": "ContextPack",
  "type": "object",
  "required": ["schema_version", "schema_id", "context_pack_id", "created_at", "task_input_id", "max_context_tokens", "reserved_output_tokens", "available_input_tokens", "total_estimated_tokens", "warnings", "errors"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"type": "string", "pattern": "^context_pack\\.schema\\.json$"},
    "context_pack_id": {"type": "string"},
    "created_at": {"type": "string"},
    "source_component": {"type": "string"},
    "task_input_id": {"type": "string"},
    "model_profile_id": {"type": "string"},
    "runtime_profile_id": {"type": "string"},
    "max_context_tokens": {"type": "integer", "minimum": 1},
    "reserved_output_tokens": {"type": "integer", "minimum": 0},
    "available_input_tokens": {"type": "integer", "minimum": 0},
    "total_estimated_tokens": {"type": "integer", "minimum": 0},
    "included_items": {"type": "array", "items": {"$ref": "#/definitions/ContextItem"}},
    "excluded_items": {"type": "array", "items": {"$ref": "#/definitions/ContextItem"}},
    "summary_items": {"type": "array", "items": {"$ref": "#/definitions/ContextItem"}},
    "redaction_report_id": {"type": "string"},
    "compression_plan_id": {"type": "string"},
    "model_compatibility_id": {"type": "string"},
    "tool_compatibility_id": {"type": "string"},
    "artifact_refs": {"type": "array", "items": {"type": "string"}},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "definitions": {
    "ContextItem": {
      "type": "object",
      "required": ["context_item_id", "title", "content", "content_hash", "inclusion_decision"],
      "properties": {
        "context_item_id": {"type": "string"},
        "title": {"type": "string"},
        "content": {"type": "string"},
        "content_hash": {"type": "string"},
        "inclusion_decision": {"type": "string"}
      }
    }
  }
}
