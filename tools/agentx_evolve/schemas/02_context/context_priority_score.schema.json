{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "context_priority_score.schema.json",
  "title": "ContextPriorityScore",
  "type": "object",
  "required": ["schema_version", "schema_id", "context_item_id", "priority_score", "reason", "warnings", "errors"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"type": "string"},
    "context_item_id": {"type": "string"},
    "priority_score": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "reason": {"type": "string"},
    "dominant_factors": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
