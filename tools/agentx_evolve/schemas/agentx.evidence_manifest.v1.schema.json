{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "agentx.evidence_manifest.v1",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "command",
    "artifacts",
    "commands_run",
    "source_mutation_detected"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "agentx.evidence_manifest.v1"
    },
    "run_id": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind"],
        "properties": {
          "path": {"type": "string"},
          "kind": {"type": "string"},
          "required": {"type": "boolean"}
        }
      }
    },
    "commands_run": {
      "type": "array",
      "items": {"type": "string"}
    },
    "source_mutation_detected": {
      "type": "boolean"
    }
  }
}
