{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "schema_id": "prompt_input_contract.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "input_contract_id", "required_fields",
    "max_input_chars"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "prompt_input_contract.schema.json"},
    "input_contract_id": {"type": "string"},
    "required_fields": {"type": "array", "items": {"type": "string"}},
    "optional_fields": {"type": "array", "items": {"type": "string"}},
    "field_types": {"type": "object"},
    "max_input_chars": {"type": "integer", "minimum": 0},
    "redaction_required": {"type": "boolean"},
    "context_sources_allowed": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
