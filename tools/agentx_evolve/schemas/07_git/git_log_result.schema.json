{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "git_log_result.schema.json",
  "title": "Git Log Result",
  "description": "Records the result of a git log operation within Agent X's Git Integration Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "result_id",
    "timestamp",
    "operation",
    "status",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "result_id": { "type": "string" },
    "timestamp": { "type": "string" },
    "operation": { "type": "string" },
    "status": { "type": "string" },
    "message": { "type": "string" },
    "stdout": { "type": "string" },
    "stderr": { "type": "string" },
    "returncode": { "type": "integer" },
    "max_count": { "type": "integer" },
    "skip": { "type": "integer" },
    "commit_range": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "commit_hash": { "type": "string" },
          "author": { "type": "string" },
          "date": { "type": "string" },
          "message": { "type": "string" },
          "refs": { "type": "string" }
        },
        "required": ["commit_hash", "author", "date", "message"]
      }
    },
    "data": { "type": "object" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
