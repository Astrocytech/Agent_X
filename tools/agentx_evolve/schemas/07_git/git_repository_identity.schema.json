{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "git_repository_identity.schema.json",
  "title": "Git Repository Identity",
  "description": "Captures the identity and provenance of a git repository within Agent X's Git Integration Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "repo_root",
    "remote_url",
    "current_branch",
    "head_commit_hash",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "repo_root": { "type": "string" },
    "remote_url": { "type": "string" },
    "current_branch": { "type": "string" },
    "head_commit_hash": { "type": "string" },
    "head_commit_message": { "type": "string" },
    "head_commit_author": { "type": "string" },
    "head_commit_timestamp": { "type": "string" },
    "default_branch": { "type": "string" },
    "is_detached_head": { "type": "boolean" },
    "is_bare_repo": { "type": "boolean" },
    "has_uncommitted_changes": { "type": "boolean" },
    "has_untracked_files": { "type": "boolean" },
    "identity_hash": { "type": "string" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
