{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "document_sync_plan.schema.json",
  "title": "DocumentSyncPlan",
  "description": "Defines the set of operations required to synchronize documentation within the Documentation Synchronization Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "plan_id",
    "created_at",
    "component_id",
    "source_scan_id"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string", "enum": ["document_sync_plan.schema.json"] },
    "plan_id": { "type": "string" },
    "created_at": { "type": "string" },
    "component_id": { "type": "string" },
    "source_scan_id": { "type": "string" },
    "operations": { "type": "array", "items": { "$ref": "document_sync_operation.schema.json" } },
    "blocked_operations": { "type": "array", "items": { "$ref": "document_sync_operation.schema.json" } },
    "summary": { "type": "object" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
