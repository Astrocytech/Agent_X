{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "document_sync_result.schema.json",
  "title": "DocumentSyncResult",
  "description": "Captures the outcome of applying a documentation sync plan within the Documentation Synchronization Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "result_id",
    "created_at",
    "plan_id",
    "status"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string", "enum": ["document_sync_result.schema.json"] },
    "result_id": { "type": "string" },
    "created_at": { "type": "string" },
    "plan_id": { "type": "string" },
    "status": { "type": "string" },
    "applied_operations": { "type": "array", "items": { "type": "string" } },
    "blocked_operations": { "type": "array", "items": { "type": "string" } },
    "changed_files": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
