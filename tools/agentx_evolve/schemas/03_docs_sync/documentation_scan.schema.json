{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DocumentScanReport",
  "type": "object",
  "required": ["schema_version", "schema_id", "component_id", "scan_id", "created_at", "repo_root"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"type": "string", "enum": ["documentation_scan.schema.json"]},
    "component_id": {"type": "string"},
    "scan_id": {"type": "string"},
    "created_at": {"type": "string"},
    "repo_root": {"type": "string"},
    "scanned_paths": {"type": "array", "items": {"type": "string"}},
    "documents": {"type": "array", "items": {"$ref": "documentation_record.schema.json"}},
    "skipped_paths": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "object"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
