{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "document_staleness_record.schema.json",
  "title": "DocumentStalenessRecord",
  "description": "Records whether a documentation file is stale relative to its related source files within the Documentation Synchronization Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "staleness_id",
    "document_id",
    "path",
    "status"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string", "enum": ["document_staleness_record.schema.json"] },
    "staleness_id": { "type": "string" },
    "document_id": { "type": "string" },
    "path": { "type": "string" },
    "status": { "type": "string" },
    "staleness_reason": { "type": "string" },
    "related_code_paths": { "type": "array", "items": { "type": "string" } },
    "related_schema_paths": { "type": "array", "items": { "type": "string" } },
    "related_test_paths": { "type": "array", "items": { "type": "string" } },
    "related_evidence_paths": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
