{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "documentation_sync_evidence_manifest.schema.json",
  "title": "DocumentationSyncEvidenceManifest",
  "description": "Indexes all evidence artifacts produced during a documentation sync run within the Documentation Synchronization Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "component_id",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string", "enum": ["documentation_sync_evidence_manifest.schema.json"] },
    "component_id": { "type": "string" },
    "validated_commit": { "type": "string" },
    "created_at": { "type": "string" },
    "scan_report_path": { "type": "string" },
    "drift_report_path": { "type": "string" },
    "sync_plan_path": { "type": "string" },
    "sync_result_path": { "type": "string" },
    "review_report_path": { "type": "string" },
    "evidence_file_hashes": { "type": "array", "items": { "type": "object" } },
    "commands_run": { "type": "array", "items": { "type": "object" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
