{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DocumentSyncResult",
  "type": "object",
  "required": ["schema_version", "schema_id", "result_id", "created_at", "plan_id", "status"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"type": "string", "enum": ["documentation_sync_result.schema.json"]},
    "result_id": {"type": "string"},
    "created_at": {"type": "string"},
    "plan_id": {"type": "string"},
    "status": {"type": "string"},
    "applied_operations": {"type": "array", "items": {"type": "string"}},
    "blocked_operations": {"type": "array", "items": {"type": "string"}},
    "changed_files": {"type": "array", "items": {"type": "string"}},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
