{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DocumentationSyncPolicyDecision",
  "type": "object",
  "required": ["schema_version", "schema_id", "operation_type", "target_authority", "decision", "reason"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"type": "string", "enum": ["documentation_manual_protection.schema.json"]},
    "operation_type": {"type": "string"},
    "target_authority": {"type": "string"},
    "decision": {"type": "string"},
    "reason": {"type": "string"},
    "policy_context_available": {"type": "boolean"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
