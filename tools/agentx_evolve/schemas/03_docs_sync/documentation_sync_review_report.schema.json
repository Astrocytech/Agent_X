{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "documentation_sync_review_report.schema.json",
  "title": "DocumentationSyncReviewReport",
  "description": "Summarises the health of all documentation sync sub-checks and renders a final verdict within the Documentation Synchronization Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "component_id",
    "created_at",
    "final_verdict"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string", "enum": ["documentation_sync_review_report.schema.json"] },
    "component_id": { "type": "string" },
    "reviewed_commit": { "type": "string" },
    "created_at": { "type": "string" },
    "scan_status": { "type": "string" },
    "drift_status": { "type": "string" },
    "link_status": { "type": "string" },
    "staleness_status": { "type": "string" },
    "manual_doc_protection_status": { "type": "string" },
    "generated_doc_update_status": { "type": "string" },
    "evidence_status": { "type": "string" },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "high_issues": { "type": "array", "items": { "type": "string" } },
    "non_blocking_followups": { "type": "array", "items": { "type": "string" } },
    "final_verdict": { "type": "string" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
