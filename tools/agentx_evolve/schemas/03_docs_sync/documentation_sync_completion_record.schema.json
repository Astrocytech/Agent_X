{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "documentation_sync_completion_record.schema.json",
  "title": "DocumentationSyncCompletionRecord",
  "description": "Final record produced when a documentation sync run completes, capturing verification results and metadata within the Documentation Synchronization Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "component_id",
    "component_name",
    "status",
    "validated_commit",
    "validated_at"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string", "enum": ["documentation_sync_completion_record.schema.json"] },
    "component_id": { "type": "string" },
    "component_name": { "type": "string" },
    "status": { "type": "string" },
    "validated_commit": { "type": "string" },
    "validated_at": { "type": "string" },
    "review_environment": { "type": "object" },
    "commands_run": { "type": "array", "items": { "type": "object" } },
    "evidence_manifest_path": { "type": "string" },
    "evidence_manifest_sha256": { "type": "string" },
    "review_report_path": { "type": "string" },
    "review_report_sha256": { "type": "string" },
    "traceability_matrix_path": { "type": "string" },
    "traceability_matrix_sha256": { "type": "string" },
    "deviation_register_path": { "type": "string" },
    "deviation_register_sha256": { "type": "string" },
    "generated_section_registry_path": { "type": "string" },
    "generated_section_registry_sha256": { "type": "string" },
    "completion_record_sha256": { "type": "string" },
    "implementation_score": { "type": "number" },
    "final_decision": { "type": "string" },
    "files_created_or_changed": { "type": "array", "items": { "type": "string" } },
    "schemas_created_or_changed": { "type": "array", "items": { "type": "string" } },
    "tests_created_or_changed": { "type": "array", "items": { "type": "string" } },
    "validated_capabilities": { "type": "array", "items": { "type": "string" } },
    "manual_doc_protection_verified": { "type": "boolean" },
    "generated_doc_updates_verified": { "type": "boolean" },
    "readme_index_rules_verified": { "type": "boolean" },
    "broken_link_detection_verified": { "type": "boolean" },
    "stale_document_detection_verified": { "type": "boolean" },
    "policy_integration_verified": { "type": "boolean" },
    "tool_mcp_adapter_integration_ready": { "type": "boolean" },
    "deviations_from_contract": { "type": "array", "items": { "type": "string" } },
    "unresolved_risks": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
