{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "capability_registry.schema.json",
  "owner_component": "PolicyCapabilityRegistry",
  "artifact_type": "capability_registry",
  "type": "object",
  "required": [
    "schema_version", "schema_id", "registry_id", "timestamp", "tools"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "schema_id": {"type": "string", "const": "capability_registry.schema.json"},
    "registry_id": {"type": "string"},
    "timestamp": {"type": "string"},
    "tools": {
      "type": "object",
      "patternProperties": {
        "^.*$": {"$ref": "#/$defs/ToolCapability"}
      },
      "additionalProperties": false
    },
    "global_rules": {
      "type": "array",
      "items": {"$ref": "#/$defs/PolicyRule"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "ToolCapability": {
      "type": "object",
      "required": ["tool_name", "capabilities"],
      "properties": {
        "tool_id": {"type": "string"},
        "timestamp": {"type": "string"},
        "tool_name": {"type": "string"},
        "description": {"type": "string"},
        "capabilities": {
          "type": "array",
          "items": {"$ref": "#/$defs/CapabilityDefinition"}
        },
        "policy_rules": {
          "type": "array",
          "items": {"$ref": "#/$defs/PolicyRule"}
        },
        "enabled": {"type": "boolean"},
        "requires_approval": {"type": "boolean"},
        "side_effect_level": {"type": "string"},
        "warnings": {"type": "array", "items": {"type": "string"}},
        "errors": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "CapabilityDefinition": {
      "type": "object",
      "required": ["name", "allowed_operations"],
      "properties": {
        "capability_id": {"type": "string"},
        "timestamp": {"type": "string"},
        "name": {"type": "string"},
        "description": {"type": "string"},
        "allowed_operations": {
          "type": "array",
          "items": {"type": "string"}
        },
        "side_effect_level": {"type": "string"},
        "requires_approval": {"type": "boolean"},
        "rate_limit_per_minute": {"type": "integer"},
        "enabled": {"type": "boolean"},
        "allowed_profiles": {
          "type": "array",
          "items": {"type": "string"}
        },
        "warnings": {"type": "array", "items": {"type": "string"}},
        "errors": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "PolicyRule": {
      "type": "object",
      "required": ["effect", "operation"],
      "properties": {
        "rule_id": {"type": "string"},
        "timestamp": {"type": "string"},
        "effect": {"type": "string"},
        "operation": {"type": "string"},
        "target_pattern": {"type": "string"},
        "reason": {"type": "string"},
        "priority": {"type": "integer"},
        "conditions": {"type": "object"},
        "warnings": {"type": "array", "items": {"type": "string"}},
        "errors": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  }
}
