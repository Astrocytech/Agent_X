{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "context_builder_review_report.schema.json",
  "title": "Context Builder Review Report",
  "type": "object",
  "required": ["schema_version", "schema_id", "component_id", "reviewed_commit", "reviewed_at", "coverage_statuses", "final_verdict"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"type": "string", "pattern": "^context_builder_review_report\\.schema\\.json$"},
    "component_id": {"type": "string"},
    "reviewed_commit": {"type": "string"},
    "reviewed_branch": {"type": "string"},
    "reviewed_at": {"type": "string"},
    "review_environment": {
      "type": "object",
      "properties": {
        "os": {"type": "string"},
        "python_version": {"type": "string"},
        "pytest_version": {"type": "string"}
      }
    },
    "commands_run": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "command", "exit_code", "status"],
        "properties": {
          "name": {"type": "string"},
          "command": {"type": "string"},
          "exit_code": {"type": "integer"},
          "status": {"type": "string", "enum": ["PASS", "FAIL", "NOT RUN"]},
          "summary": {"type": "string"},
          "output_artifact": {"type": "string"},
          "output_sha256": {"type": "string"}
        }
      }
    },
    "coverage_statuses": {
      "type": "object",
      "patternProperties": {
        ".*": {"type": "string", "enum": ["PASS", "PARTIAL", "FAIL", "NOT CHECKED", "NOT APPLICABLE"]}
      }
    },
    "blockers": {"type": "array", "items": {"type": "string"}},
    "high_issues": {"type": "array", "items": {"type": "string"}},
    "non_blocking_followups": {"type": "array", "items": {"type": "string"}},
    "deviation_register": {"type": "array", "items": {"type": "object"}},
    "evidence_manifest_path": {"type": "string"},
    "evidence_manifest_sha256": {"type": "string"},
    "review_report_sha256": {"type": "string"},
    "completion_record_path": {"type": "string"},
    "completion_record_sha256": {"type": "string"},
    "implementation_rating": {"type": "number"},
    "final_verdict": {"type": "string", "enum": ["DONE", "NOT DONE"]}
  }
}
