{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "context_model_compatibility.schema.json",
  "title": "ContextModelCompatibility",
  "type": "object",
  "required": ["schema_version", "schema_id", "decision_id", "model_profile_id", "fits", "decision", "warnings", "errors"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"type": "string"},
    "decision_id": {"type": "string"},
    "model_profile_id": {"type": "string"},
    "runtime_profile_id": {"type": "string"},
    "context_window_tokens": {"type": "integer", "minimum": 0},
    "estimated_input_tokens": {"type": "integer", "minimum": 0},
    "reserved_output_tokens": {"type": "integer", "minimum": 0},
    "fits": {"type": "boolean"},
    "required_reductions": {"type": "integer", "minimum": 0},
    "decision": {"type": "string"},
    "reason": {"type": "string"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
