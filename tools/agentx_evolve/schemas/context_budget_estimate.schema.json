{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "context_budget_estimate.schema.json",
  "title": "ContextBudgetEstimate",
  "type": "object",
  "required": ["schema_version", "schema_id", "max_context_tokens", "reserved_output_tokens", "available_input_tokens", "total_estimated_tokens", "fits", "warnings", "errors"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"type": "string"},
    "max_context_tokens": {"type": "integer", "minimum": 1},
    "reserved_output_tokens": {"type": "integer", "minimum": 0},
    "available_input_tokens": {"type": "integer", "minimum": 0},
    "total_estimated_tokens": {"type": "integer", "minimum": 0},
    "fits": {"type": "boolean"},
    "over_budget_tokens": {"type": "integer", "minimum": 0},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
