{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "local_model_inventory.schema.json",
  "title": "Local Model Inventory",
  "type": "object",
  "required": ["inventory_id", "created_at"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "local_model_inventory.schema.json"},
    "inventory_id": {"type": "string"},
    "created_at": {"type": "string"},
    "approved_model_roots": {"type": "array", "items": {"type": "string"}},
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["model_id", "model_path"],
        "properties": {
          "model_id": {"type": "string"},
          "model_path": {"type": "string"},
          "enabled": {"type": "boolean"},
          "expected_size_bytes": {"type": ["integer", "null"]},
          "expected_sha256": {"type": ["string", "null"]},
          "last_seen_at": {"type": ["string", "null"]},
          "warnings": {"type": "array", "items": {"type": "string"}},
          "errors": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
