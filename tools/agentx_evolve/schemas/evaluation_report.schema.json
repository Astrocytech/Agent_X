{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "evaluation_report.schema.json",
  "title": "EvaluationReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "report_id",
    "run_id",
    "suite_id",
    "status",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "schema_id": {
      "type": "string"
    },
    "report_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "suite_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "score_summary": {
      "type": "object"
    },
    "threshold_summary": {
      "type": "object"
    },
    "regression_summary": {
      "type": "object"
    },
    "case_summaries": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}