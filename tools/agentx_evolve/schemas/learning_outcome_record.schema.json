{"$schema":"http://json-schema.org/draft-07/schema#","$id":"learning_outcome_record.schema.json","title":"LearningOutcomeRecord","description":"Records an implementation outcome for long-term learning","type":"object","required":["schema_version","schema_id","outcome_id","session_id","attempted_task","validation_outcome","created_at","tags","evidence_refs","warnings","errors"],"properties":{"schema_version":{"type":"string","description":"Schema version string"},"schema_id":{"type":"string","description":"Schema identifier"},"outcome_id":{"type":"string","description":"Unique outcome identifier"},"session_id":{"type":"string","description":"Session identifier this outcome belongs to"},"attempted_task":{"type":"string","description":"The task that was attempted"},"proposal_type":{"type":"string","description":"Type of proposal (e.g. IMPLEMENT_PATCH, FIX_VALIDATION)"},"files_changed":{"type":"array","items":{"type":"string"},"description":"Files that were changed"},"model_used":{"type":"string","description":"Model used for the implementation"},"validation_outcome":{"type":"string","description":"Validation result (e.g. PASS, FAIL, PARTIAL)"},"rollback_outcome":{"type":"string","description":"Rollback result if applicable"},"failure_reason":{"type":"string","description":"Reason for failure if outcome was unsuccessful"},"successful_strategy":{"type":"string","description":"Description of what strategy worked"},"future_recommendation":{"type":"string","description":"Recommendation for future similar tasks"},"created_at":{"type":"string","description":"UTC ISO-8601 timestamp of creation"},"outcome_hash":{"type":"string","description":"SHA-256 hex digest of the outcome record"},"tags":{"type":"array","items":{"type":"string"},"description":"Tags for cross-session discovery"},"evidence_refs":{"type":"array","items":{"type":"string"},"description":"References to evidence artifacts"},"warnings":{"type":"array","items":{"type":"string"},"description":"Warning messages"},"errors":{"type":"array","items":{"type":"string"},"description":"Error messages"}}}
