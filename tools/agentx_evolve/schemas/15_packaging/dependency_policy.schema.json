{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "dependency_policy.schema.json",
  "title": "Dependency Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_name",
    "allowed_licenses",
    "blocked_packages",
    "max_depth"
  ],
  "properties": {
    "policy_name": { "type": "string", "description": "Name of the dependency policy" },
    "allowed_licenses": { "type": "array", "items": { "type": "string" }, "description": "List of allowed license identifiers" },
    "blocked_packages": { "type": "array", "items": { "type": "string" }, "description": "List of blocked package names" },
    "max_depth": { "type": "integer", "minimum": 0, "description": "Maximum dependency tree depth allowed" },
    "allowed_packages": { "type": "array", "items": { "type": "string" }, "description": "List of explicitly allowed packages" },
    "blocked_licenses": { "type": "array", "items": { "type": "string" }, "description": "List of blocked license identifiers" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
