{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "dependency_lock.schema.json",
  "title": "Dependency Lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lock_id",
    "dependencies",
    "resolved_at"
  ],
  "properties": {
    "lock_id": { "type": "string", "description": "Unique identifier for the lock record" },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "resolved_url": { "type": "string" },
          "sha256": { "type": "string" }
        },
        "required": ["name", "version"]
      },
      "description": "List of locked dependencies with their resolved versions"
    },
    "resolved_at": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp of resolution" },
    "lock_sha256": { "type": "string", "description": "SHA-256 hash of the lock content" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
