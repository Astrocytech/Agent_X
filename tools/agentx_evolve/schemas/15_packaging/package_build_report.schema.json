{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "package_build_report.schema.json",
  "title": "Package Build Report",
  "description": "Schema for the package build report",
  "schema_version": "1.0",
  "schema_id": {
    "const": "package_build_report.schema.json"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "report_id",
    "created_at",
    "source_component",
    "manifest_id",
    "package_format",
    "staging_root",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "package_build_report.schema.json",
      "description": "Unique schema identifier"
    },
    "report_id": {
      "type": "string",
      "description": "Unique report identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "source_component": {
      "type": "string",
      "description": "Name of the source component"
    },
    "manifest_id": {
      "type": "string",
      "description": "Reference to the package manifest"
    },
    "package_format": {
      "type": "string",
      "description": "Format of the built package"
    },
    "staging_root": {
      "type": "string",
      "description": "Root directory used for staging"
    },
    "package_artifact": {
      "type": "string",
      "description": "Path to the resulting package artifact"
    },
    "files_copied": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of files successfully copied"
    },
    "files_rejected": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of files rejected during build"
    },
    "status": {
      "type": "string",
      "enum": ["READY", "BUILT", "VALIDATED", "BLOCKED", "FAILED", "PARTIAL"],
      "description": "Build status"
    },
    "commands_run": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of commands executed during build"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
