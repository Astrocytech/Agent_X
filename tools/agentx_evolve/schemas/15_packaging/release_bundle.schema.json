{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "release_bundle.schema.json",
  "title": "Release Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "version",
    "artifacts",
    "manifest_ref"
  ],
  "properties": {
    "bundle_id": { "type": "string", "description": "Unique identifier for the release bundle" },
    "version": { "type": "string", "description": "Version of the release bundle" },
    "artifacts": { "type": "array", "items": { "type": "string" }, "description": "List of artifact identifiers included in the bundle" },
    "manifest_ref": { "type": "string", "description": "Reference to the associated manifest" },
    "created_at": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp of creation" },
    "created_by": { "type": "string", "description": "Name or ID of the creator" },
    "bundle_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$", "description": "SHA-256 hash of the bundle" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
