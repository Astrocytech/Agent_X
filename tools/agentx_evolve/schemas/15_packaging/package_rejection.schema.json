{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "package_rejection.schema.json",
  "title": "Package Rejection",
  "description": "Schema for a package file rejection record",
  "schema_version": "1.0",
  "schema_id": {
    "const": "package_rejection.schema.json"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "rejection_id",
    "created_at",
    "relative_path",
    "reason_code",
    "reason",
    "severity"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "package_rejection.schema.json",
      "description": "Unique schema identifier"
    },
    "rejection_id": {
      "type": "string",
      "description": "Unique rejection identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "relative_path": {
      "type": "string",
      "description": "Relative path of the rejected file"
    },
    "reason_code": {
      "type": "string",
      "enum": [
        "FORBIDDEN_PATH",
        "FORBIDDEN_EXTENSION",
        "FORBIDDEN_RUNTIME_ROOT",
        "FORBIDDEN_ARCHIVE_NAME",
        "NOT_TRACKED",
        "EXCEEDS_SIZE_LIMIT",
        "UNSAFE_PERMISSIONS",
        "ABSOLUTE_PATH_ENTRY",
        "PATH_TRAVERSAL",
        "SYMLINK_ESCAPE",
        "HARDLINK_ESCAPE",
        "DEVICE_FILE",
        "RUNTIME_ARTIFACT",
        "SECRET_LIKE_FILE",
        "UNSUPPORTED_FORMAT",
        "EXCLUDED_BY_PATTERN",
        "NOT_INCLUDED_BY_PATTERN",
        "MISSING_REQUIRED",
        "DUPLICATE_ENTRY"
      ],
      "description": "Machine-readable rejection reason code"
    },
    "reason": {
      "type": "string",
      "description": "Human-readable rejection reason"
    },
    "severity": {
      "type": "string",
      "enum": ["BLOCKER", "WARNING", "INFO"],
      "description": "Severity level of the rejection"
    },
    "safe_detail": {
      "type": "string",
      "description": "Safe detail about the rejection"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
