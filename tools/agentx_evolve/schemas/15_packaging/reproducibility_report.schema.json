{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "reproducibility_report.schema.json",
  "title": "Reproducibility Report",
  "description": "Schema for the reproducibility report",
  "schema_version": "1.0",
  "schema_id": {
    "const": "reproducibility_report.schema.json"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "report_id",
    "created_at",
    "source_component",
    "first_build_artifact",
    "first_build_sha256",
    "second_build_artifact",
    "second_build_sha256",
    "hashes_match",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "reproducibility_report.schema.json",
      "description": "Unique schema identifier"
    },
    "report_id": {
      "type": "string",
      "description": "Unique report identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "source_component": {
      "type": "string",
      "description": "Name of the source component"
    },
    "first_build_artifact": {
      "type": "string",
      "description": "Path to the first build artifact"
    },
    "first_build_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of the first build"
    },
    "second_build_artifact": {
      "type": "string",
      "description": "Path to the second build artifact"
    },
    "second_build_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of the second build"
    },
    "hashes_match": {
      "type": "boolean",
      "description": "Whether the hashes of both builds match"
    },
    "normalized_timestamp": {
      "type": "boolean",
      "description": "Whether timestamps were normalized"
    },
    "normalized_permissions": {
      "type": "object",
      "additionalProperties": true,
      "description": "Permission normalization settings"
    },
    "normalized_owner_group": {
      "type": "boolean",
      "description": "Whether owner/group were normalized"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "PARTIAL", "FAIL", "BLOCKED", "NOT CHECKED", "NOT RUN", "NOT APPLICABLE", "DEFERRED SAFELY"],
      "description": "Reproducibility status"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
