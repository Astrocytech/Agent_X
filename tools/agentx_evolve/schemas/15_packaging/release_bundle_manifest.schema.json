{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "release_bundle_manifest.schema.json",
  "title": "Release Bundle Manifest",
  "description": "Schema for the release bundle manifest",
  "schema_version": "1.0",
  "schema_id": {
    "const": "release_bundle_manifest.schema.json"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "bundle_manifest_id",
    "created_at",
    "source_component",
    "bundle_name",
    "bundle_version"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "release_bundle_manifest.schema.json",
      "description": "Unique schema identifier"
    },
    "bundle_manifest_id": {
      "type": "string",
      "description": "Unique bundle manifest identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "source_component": {
      "type": "string",
      "description": "Name of the source component"
    },
    "bundle_name": {
      "type": "string",
      "description": "Name of the release bundle"
    },
    "bundle_version": {
      "type": "string",
      "description": "Version of the release bundle"
    },
    "bundle_artifact": {
      "type": "string",
      "description": "Path to the bundle artifact"
    },
    "bundle_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of the bundle artifact"
    },
    "included_artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of artifacts included in the bundle"
    },
    "included_hashes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of hashes of included artifacts"
    },
    "provenance_ref": {
      "type": "string",
      "description": "Reference to provenance record"
    },
    "evidence_ref": {
      "type": "string",
      "description": "Reference to evidence record"
    },
    "promotion_status": {
      "type": "string",
      "description": "Status of the promotion"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
