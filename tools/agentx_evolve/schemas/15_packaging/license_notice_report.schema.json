{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "license_notice_report.schema.json",
  "title": "License Notice Report",
  "description": "Schema for the license notice report",
  "schema_version": "1.0",
  "schema_id": {
    "const": "license_notice_report.schema.json"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "report_id",
    "created_at",
    "source_component",
    "required_license_files",
    "found_license_files",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "license_notice_report.schema.json",
      "description": "Unique schema identifier"
    },
    "report_id": {
      "type": "string",
      "description": "Unique report identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "source_component": {
      "type": "string",
      "description": "Name of the source component"
    },
    "required_license_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of required license files"
    },
    "found_license_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of license files found"
    },
    "missing_license_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Required license files that are missing"
    },
    "notice_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Notice files found"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "PARTIAL", "FAIL", "BLOCKED", "NOT CHECKED", "NOT RUN", "NOT APPLICABLE", "DEFERRED SAFELY"],
      "description": "Report status"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
