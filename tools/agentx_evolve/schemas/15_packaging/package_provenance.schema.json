{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "package_provenance.schema.json",
  "title": "Package Provenance",
  "description": "Schema for package provenance information",
  "schema_version": "1.0",
  "schema_id": {
    "const": "package_provenance.schema.json"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "provenance_id",
    "created_at",
    "source_component",
    "package_name",
    "package_version"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "package_provenance.schema.json",
      "description": "Unique schema identifier"
    },
    "provenance_id": {
      "type": "string",
      "description": "Unique provenance identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "source_component": {
      "type": "string",
      "description": "Name of the source component"
    },
    "package_name": {
      "type": "string",
      "description": "Name of the package"
    },
    "package_version": {
      "type": "string",
      "description": "Version of the package"
    },
    "source_commit": {
      "type": "string",
      "description": "Source commit hash"
    },
    "source_branch": {
      "type": "string",
      "description": "Source branch name"
    },
    "source_tree_status": {
      "type": "string",
      "enum": ["clean", "dirty", "unknown"],
      "description": "Status of the source tree"
    },
    "manifest_path": {
      "type": "string",
      "description": "Path to the package manifest"
    },
    "manifest_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of the manifest"
    },
    "build_command": {
      "type": "string",
      "description": "Command used to build the package"
    },
    "build_environment": {
      "type": "object",
      "additionalProperties": true,
      "description": "Build environment variables and settings"
    },
    "builder_version": {
      "type": "string",
      "description": "Version of the builder tool"
    },
    "package_artifact": {
      "type": "string",
      "description": "Path to the package artifact"
    },
    "package_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of the package artifact"
    },
    "reproducibility_settings": {
      "type": "object",
      "additionalProperties": true,
      "description": "Settings for reproducible builds"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
