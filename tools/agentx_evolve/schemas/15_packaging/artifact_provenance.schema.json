{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "artifact_provenance.schema.json",
  "title": "Artifact Provenance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "source",
    "build_command",
    "builder",
    "timestamp"
  ],
  "properties": {
    "artifact_id": { "type": "string", "description": "Unique identifier for the artifact" },
    "source": { "type": "string", "description": "Source repository or origin" },
    "build_command": { "type": "string", "description": "Command used to build the artifact" },
    "builder": { "type": "string", "description": "Name or ID of the builder" },
    "timestamp": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp of the build" },
    "artifact_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$", "description": "SHA-256 hash of the artifact" },
    "build_environment": { "type": "object", "description": "Build environment details" },
    "dependencies": { "type": "array", "items": { "type": "string" }, "description": "Build dependencies" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
