{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dependency_inventory.schema.json",
  "title": "Dependency Inventory",
  "description": "Schema for the dependency inventory",
  "schema_version": "1.0",
  "schema_id": {
    "const": "dependency_inventory.schema.json"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "inventory_id",
    "created_at",
    "source_component",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "dependency_inventory.schema.json",
      "description": "Unique schema identifier"
    },
    "inventory_id": {
      "type": "string",
      "description": "Unique inventory identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "source_component": {
      "type": "string",
      "description": "Name of the source component"
    },
    "dependency_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Dependency specification files found"
    },
    "lock_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Lock files found"
    },
    "resolved_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "description": "Name of the dependency" },
          "version": { "type": "string", "description": "Version of the dependency" },
          "source": { "type": "string", "description": "Source of the dependency" }
        }
      },
      "description": "List of resolved dependencies"
    },
    "unpinned_dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Dependencies that are not pinned to specific versions"
    },
    "network_resolution_used": {
      "type": "boolean",
      "description": "Whether network resolution was used"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "PARTIAL", "FAIL", "BLOCKED", "NOT CHECKED", "NOT RUN", "NOT APPLICABLE", "DEFERRED SAFELY"],
      "description": "Inventory status"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
