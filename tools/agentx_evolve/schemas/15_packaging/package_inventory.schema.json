{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "package_inventory.schema.json",
  "title": "Package Inventory",
  "description": "Schema for the package inventory of files",
  "schema_version": "1.0",
  "schema_id": {
    "const": "package_inventory.schema.json"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "inventory_id",
    "created_at",
    "source_component",
    "manifest_id",
    "source_root",
    "files"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "package_inventory.schema.json",
      "description": "Unique schema identifier"
    },
    "inventory_id": {
      "type": "string",
      "description": "Unique inventory identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "source_component": {
      "type": "string",
      "description": "Name of the source component"
    },
    "manifest_id": {
      "type": "string",
      "description": "Reference to the package manifest"
    },
    "source_root": {
      "type": "string",
      "description": "Root directory of the source code"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relative_path", "absolute_path", "file_size_bytes", "sha256", "included"],
        "properties": {
          "relative_path": { "type": "string", "description": "Relative path of the file" },
          "absolute_path": { "type": "string", "description": "Absolute path of the file" },
          "file_size_bytes": { "type": "integer", "minimum": 0, "description": "File size in bytes" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$", "description": "SHA-256 hash of the file" },
          "included": { "type": "boolean", "description": "Whether the file is included in the package" },
          "source_tracked": { "type": "boolean", "description": "Whether the file is tracked by version control" },
          "is_symlink": { "type": "boolean", "description": "Whether the file is a symlink" },
          "symlink_target": { "type": "string", "description": "Target of the symlink if applicable" },
          "normalized_archive_path": { "type": "string", "description": "Normalized path within the archive" },
          "reason": { "type": "string", "description": "Reason for inclusion or exclusion" },
          "warnings": { "type": "array", "items": { "type": "string" }, "description": "Warning messages" },
          "errors": { "type": "array", "items": { "type": "string" }, "description": "Error messages" }
        }
      },
      "description": "List of file records in the inventory"
    },
    "rejections": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of rejection identifiers or reasons"
    },
    "selected_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of selected files"
    },
    "rejected_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of rejected files"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
