{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "distribution_evidence.schema.json",
  "title": "Distribution Evidence",
  "description": "Schema for distribution evidence records",
  "schema_version": "1.0",
  "schema_id": {
    "const": "distribution_evidence.schema.json"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "evidence_id",
    "created_at",
    "source_component",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "distribution_evidence.schema.json",
      "description": "Unique schema identifier"
    },
    "evidence_id": {
      "type": "string",
      "description": "Unique evidence identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "source_component": {
      "type": "string",
      "description": "Name of the source component"
    },
    "package_manifest_ref": {
      "type": "string",
      "description": "Reference to the package manifest"
    },
    "package_inventory_ref": {
      "type": "string",
      "description": "Reference to the package inventory"
    },
    "package_build_report_ref": {
      "type": "string",
      "description": "Reference to the package build report"
    },
    "package_validation_report_ref": {
      "type": "string",
      "description": "Reference to the package validation report"
    },
    "hash_manifest_ref": {
      "type": "string",
      "description": "Reference to the hash manifest"
    },
    "provenance_ref": {
      "type": "string",
      "description": "Reference to the provenance record"
    },
    "dependency_lock_report_ref": {
      "type": "string",
      "description": "Reference to the dependency lock report"
    },
    "install_validation_report_ref": {
      "type": "string",
      "description": "Reference to the install validation report"
    },
    "release_bundle_manifest_ref": {
      "type": "string",
      "description": "Reference to the release bundle manifest"
    },
    "commands_run": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of commands executed"
    },
    "artifact_refs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "References to artifacts"
    },
    "sha256_refs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "References to SHA-256 hashes"
    },
    "rejections": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Rejection records"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "PARTIAL", "FAIL", "BLOCKED", "NOT CHECKED", "NOT RUN", "NOT APPLICABLE", "DEFERRED SAFELY"],
      "description": "Evidence status"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
