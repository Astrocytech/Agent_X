{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "local_model_runtime_review_report.schema.json",
  "title": "Local Model Runtime Review Report",
  "type": "object",
  "required": ["component_id", "reviewed_commit", "final_verdict"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "local_model_runtime_review_report.schema.json"},
    "component_id": {"const": "AGENTX_LOCAL_MODEL_RUNTIME_PROFILE"},
    "review_document_id": {"type": "string"},
    "review_document_version": {"type": "string"},
    "reviewed_commit": {"type": "string"},
    "reviewed_branch": {"type": "string"},
    "reviewed_at": {"type": "string"},
    "reviewer": {"type": "string"},
    "review_environment": {"type": "object"},
    "working_tree_start_status": {"type": "string"},
    "working_tree_end_status": {"type": "string"},
    "commands_run": {"type": "array", "items": {"type": "object"}},
    "command_output_hashes": {"type": "array", "items": {"type": "object"}},
    "coverage_statuses": {"type": "object"},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "high_issues": {"type": "array", "items": {"type": "string"}},
    "non_blocking_followups": {"type": "array", "items": {"type": "string"}},
    "deviation_register": {"type": "array", "items": {"type": "object"}},
    "evidence_manifest_path": {"type": "string"},
    "evidence_manifest_sha256": {"type": "string"},
    "review_report_path": {"type": "string"},
    "review_report_sha256": {"type": "string"},
    "completion_record_path": {"type": "string"},
    "completion_record_sha256": {"type": "string"},
    "implementation_rating": {"type": "number"},
    "final_verdict": {"type": "string"}
  }
}
