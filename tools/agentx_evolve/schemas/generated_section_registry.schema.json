{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GeneratedSectionRegistry",
  "type": "object",
  "required": ["schema_version", "schema_id", "registry_id", "created_at", "component_id", "sections"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"type": "string", "enum": ["generated_section_registry.schema.json"]},
    "registry_id": {"type": "string"},
    "created_at": {"type": "string"},
    "component_id": {"type": "string"},
    "sections": {
      "type": "array",
      "items": {"$ref": "generated_document_section.schema.json"}
    },
    "duplicate_section_ids": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
