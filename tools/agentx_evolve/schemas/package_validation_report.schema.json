{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "package_validation_report.schema.json",
  "title": "Package Validation Report",
  "description": "Schema for the package validation report",
  "schema_version": "1.0",
  "schema_id": {
    "const": "package_validation_report.schema.json"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "report_id",
    "created_at",
    "source_component",
    "package_artifact",
    "package_format",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "package_validation_report.schema.json",
      "description": "Unique schema identifier"
    },
    "report_id": {
      "type": "string",
      "description": "Unique report identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "source_component": {
      "type": "string",
      "description": "Name of the source component"
    },
    "package_artifact": {
      "type": "string",
      "description": "Path to the package artifact being validated"
    },
    "package_format": {
      "type": "string",
      "description": "Format of the package"
    },
    "expected_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of expected files in the package"
    },
    "actual_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of actual files found in the package"
    },
    "missing_required_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Required files that are missing"
    },
    "unexpected_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Files found but not expected"
    },
    "forbidden_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Forbidden files found in the package"
    },
    "archive_escape_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Files that escape the archive root"
    },
    "absolute_path_entries": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Entries with absolute paths in the archive"
    },
    "runtime_artifacts_found": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Runtime artifacts found in the package"
    },
    "secret_like_files_found": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Files resembling secrets found in the package"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "PARTIAL", "FAIL", "BLOCKED", "NOT CHECKED", "NOT RUN", "NOT APPLICABLE", "DEFERRED SAFELY"],
      "description": "Validation status"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
