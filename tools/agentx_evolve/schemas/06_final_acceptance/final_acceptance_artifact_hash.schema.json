{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FinalAcceptanceArtifactHash",
  "type": "object",
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"enum": ["final_acceptance_artifact_hash.schema.json"]},
    "source_component": {"type": "string"},
    "self_hash_mode": {"type": "string"},
    "self_hash_reason": {"type": "string"},
    "hashed_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_path", "sha256"],
        "properties": {
          "artifact_path": {"type": "string"},
          "sha256": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "unhashed_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_path", "reason"],
        "properties": {
          "artifact_path": {"type": "string"},
          "reason": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "required": [
    "schema_version", "schema_id", "source_component",
    "self_hash_mode", "hashed_artifacts", "unhashed_artifacts"
  ],
  "additionalProperties": false
}
