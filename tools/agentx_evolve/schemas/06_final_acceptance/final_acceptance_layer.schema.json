    "expected_review_report_path": {"type": "string"},
    "expected_evidence_manifest_path": {"type": "string"},
    "acceptance_modes_required": {"type": "array", "items": {"type": "string"}},
    "deferral_modes_allowed": {"type": "array", "items": {"type": "string"}},
    "expected_evidence_aliases": {"type": "array", "items": {"type": "string"}},
    "stale_after_days": {"type": ["integer", "null"]},
    "bootstrap_self_layer": {"type": "boolean"},
