{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "monitoring_artifact_provenance.schema.json",
  "title": "Monitoring Artifact Provenance",
  "description": "Schema for tracking artifact provenance within the Monitoring Observability Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "provenance_id",
    "artifact_path",
    "artifact_type",
    "created_at",
    "source_component",
    "sha256"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "monitoring_artifact_provenance.schema.json",
      "description": "Unique schema identifier"
    },
    "provenance_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique provenance record identifier"
    },
    "artifact_path": {
      "type": "string",
      "minLength": 1,
      "description": "Path to the artifact"
    },
    "artifact_type": {
      "type": "string",
      "enum": ["event_log", "metric_log", "trace_log", "alert_log", "health_report", "runtime_status", "config", "manifest", "report", "record"],
      "description": "Type of artifact"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the artifact was created"
    },
    "source_component": {
      "type": "string",
      "minLength": 1,
      "description": "Component that created the artifact"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of the artifact content"
    },
    "size_bytes": {
      "type": "integer",
      "description": "Size of the artifact in bytes"
    },
    "session_id": {
      "type": "string",
      "description": "Session identifier associated with the artifact"
    },
    "run_id": {
      "type": "string",
      "description": "Run identifier associated with the artifact"
    },
    "labels": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Key-value labels for the artifact"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
