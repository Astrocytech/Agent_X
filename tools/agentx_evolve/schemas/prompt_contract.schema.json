{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "schema_id": "prompt_contract.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "prompt_contract_id", "prompt_name",
    "owner_component", "prompt_type", "allowed_roles", "input_contract_id",
    "output_contract_id"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "prompt_contract.schema.json"},
    "prompt_contract_id": {"type": "string"},
    "prompt_name": {"type": "string"},
    "description": {"type": "string"},
    "owner_component": {"type": "string"},
    "prompt_type": {"type": "string", "enum": ["SYSTEM", "DEVELOPER", "ROLE", "TASK", "TOOL_USE", "REVIEW", "VALIDATION", "REPAIR", "PROMOTION"]},
    "allowed_roles": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "allowed_task_types": {"type": "array", "items": {"type": "string"}},
    "allowed_model_profiles": {"type": "array", "items": {"type": "string"}},
    "allowed_tool_names": {"type": "array", "items": {"type": "string"}},
    "input_contract_id": {"type": "string"},
    "output_contract_id": {"type": "string"},
    "safety_rule_ids": {"type": "array", "items": {"type": "string"}},
    "provenance_required": {"type": "boolean"},
    "runtime_binding_required": {"type": "boolean"},
    "versioning_required": {"type": "boolean"},
    "active_version_id": {"type": "string"},
    "status": {"type": "string", "enum": ["DRAFT", "ACTIVE", "DEPRECATED", "RETIRED", "BLOCKED"]},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
