{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "schema_id": "prompt_contract.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["prompt_id", "task_type", "template", "output_schema"],
  "properties": {
    "schema_version": {"type": "string"},
    "prompt_id": {"type": "string"},
    "prompt_version": {"type": "string"},
    "status": {"type": "string", "enum": ["ACTIVE", "DEPRECATED", "RETIRED"]},
    "task_type": {"type": "string"},
    "input_schema": {"type": "string"},
    "output_schema": {"type": "string"},
    "allowed_tools": {"type": "array", "items": {"type": "string"}},
    "forbidden_behavior": {"type": "array", "items": {"type": "string"}},
    "model_profiles": {"type": "array", "items": {"type": "string"}},
    "template": {"type": "string"},
    "test_cases": {"type": "array", "items": {"type": "object"}},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
