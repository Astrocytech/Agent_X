{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentx.example/schemas/inverse_science_negative_knowledge",
  "title": "Inverse Science Negative Knowledge",
  "type": "object",
  "required": [
    "entry_id",
    "candidate_id",
    "plan_id",
    "schema_version",
    "failure_type",
    "description",
    "risk_adjustment",
    "gain_adjustment",
    "created_at_utc"
  ],
  "properties": {
    "entry_id": {
      "type": "string",
      "pattern": "^INVSCI-NEG-[A-Z0-9-]+$"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^INVSCI-CAND-[A-Z0-9-]+$"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^INVSCI-PLAN-[A-Z0-9-]+$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "failure_type": {
      "type": "string",
      "enum": [
        "target_failure",
        "constraint_failure",
        "governance_failure",
        "evidence_failure",
        "measurement_failure",
        "model_failure",
        "complexity_failure",
        "reversibility_failure",
        "integration_failure"
      ]
    },
    "description": {
      "type": "string"
    },
    "risk_adjustment": {
      "type": "number",
      "description": "Amount to increase risk/cost for similar candidates (positive value)"
    },
    "gain_adjustment": {
      "type": "number",
      "description": "Amount to decrease expected gain for similar candidates (negative value)"
    },
    "similar_candidate_pattern": {
      "type": "string"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
