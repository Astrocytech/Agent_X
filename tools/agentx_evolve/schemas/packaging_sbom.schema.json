{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "packaging_sbom.schema.json",
  "title": "Packaging SBOM Metadata",
  "description": "Schema for SBOM metadata per CONTRACT section 23.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "sbom_id",
    "created_at",
    "source_component",
    "source_commit",
    "package_name",
    "package_version",
    "components",
    "generation_mode",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "packaging_sbom.schema.json",
      "description": "Unique schema identifier"
    },
    "sbom_id": {
      "type": "string",
      "description": "Unique SBOM identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "source_component": {
      "type": "string",
      "const": "PackagingDistribution",
      "description": "Name of the source component"
    },
    "source_commit": {
      "type": "string",
      "description": "Git commit hash of the source"
    },
    "package_name": {
      "type": "string",
      "description": "Name of the package"
    },
    "package_version": {
      "type": "string",
      "description": "Version of the package"
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "description": "Component name" },
          "version": { "type": "string", "description": "Component version" },
          "purl": { "type": "string", "description": "Package URL" },
          "source": { "type": "string", "description": "Source of the component" }
        }
      },
      "description": "List of software components in the package"
    },
    "generation_mode": {
      "type": "string",
      "enum": ["BASIC_METADATA", "DEFERRED_SAFELY"],
      "description": "How the SBOM was generated"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "DEFERRED SAFELY", "FAIL"],
      "description": "SBOM generation status"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
