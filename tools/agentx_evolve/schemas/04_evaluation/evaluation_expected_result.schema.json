{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "evaluation_expected_result.schema.json",
  "title": "EvaluationExpectedResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "expected_result_id",
    "expected_status",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "schema_id": {
      "type": "string"
    },
    "expected_result_id": {
      "type": "string"
    },
    "expected_status": {
      "type": "string"
    },
    "expected_failure_class": {
      "type": "string"
    },
    "comparators": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "required_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "minimum_score": {
      "type": "number"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}