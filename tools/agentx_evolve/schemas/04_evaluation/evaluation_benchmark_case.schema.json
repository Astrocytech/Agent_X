{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "evaluation_benchmark_case.schema.json",
  "title": "BenchmarkCase",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "case_id",
    "case_type",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "schema_id": {
      "type": "string"
    },
    "case_id": {
      "type": "string"
    },
    "case_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "case_type": {
      "type": "string",
      "enum": [
        "STATIC_EXPECTED_RESULT",
        "TOOL_CALL_EXPECTED_RESULT",
        "POLICY_DENIAL_EXPECTED_RESULT",
        "REGRESSION_EXPECTED_FAILURE",
        "ARTIFACT_EXPECTED_RESULT",
        "REPORT_GENERATION_EXPECTED_RESULT",
        "NEGATIVE_FIXTURE_VALIDATION"
      ]
    },
    "target_component": {
      "type": "string"
    },
    "severity": {
      "type": "string"
    },
    "weight": {
      "type": "number"
    },
    "input_ref": {
      "type": "string"
    },
    "input_payload": {
      "type": "object"
    },
    "expected_result": {
      "type": "object"
    },
    "threshold_id": {
      "type": "string"
    },
    "timeout_seconds": {
      "type": "integer"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}