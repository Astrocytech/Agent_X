{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "evaluation_threshold.schema.json",
  "title": "EvaluationThreshold",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "threshold_id",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "schema_id": {
      "type": "string"
    },
    "threshold_id": {
      "type": "string"
    },
    "minimum_pass_rate": {
      "type": "number"
    },
    "minimum_weighted_score": {
      "type": "number"
    },
    "maximum_regression_count": {
      "type": "integer"
    },
    "maximum_error_count": {
      "type": "integer"
    },
    "maximum_blocked_count": {
      "type": "integer"
    },
    "allow_blocked_cases": {
      "type": "boolean"
    },
    "allow_error_cases": {
      "type": "boolean"
    },
    "required_case_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_score_delta": {
      "type": "number"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}