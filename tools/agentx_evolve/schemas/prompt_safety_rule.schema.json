{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "schema_id": "prompt_safety_rule.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "safety_rule_id", "name",
    "safety_level", "description"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "prompt_safety_rule.schema.json"},
    "safety_rule_id": {"type": "string"},
    "name": {"type": "string"},
    "safety_level": {"type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]},
    "description": {"type": "string"},
    "forbidden_content_patterns": {"type": "array", "items": {"type": "string"}},
    "required_instructions": {"type": "array", "items": {"type": "string"}},
    "tool_use_constraints": {"type": "array", "items": {"type": "string"}},
    "model_use_constraints": {"type": "array", "items": {"type": "string"}},
    "injection_defense_required": {"type": "boolean"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
