{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "monitoring_evidence_manifest.schema.json",
  "title": "Monitoring Evidence Manifest",
  "description": "Schema for a monitoring evidence manifest within the Monitoring Observability Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "evidence_manifest_id",
    "created_at",
    "source_component"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "monitoring_evidence_manifest.schema.json",
      "description": "Unique schema identifier"
    },
    "evidence_manifest_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique evidence manifest identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "source_component": {
      "type": "string",
      "minLength": 1,
      "description": "Component that generated the manifest"
    },
    "session_id": {
      "type": "string",
      "description": "Associated session identifier"
    },
    "component_id": {
      "type": "string",
      "description": "Identifier of the component"
    },
    "validated_commit": {
      "type": "string",
      "description": "Commit hash that was validated"
    },
    "evidence_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of evidence file paths"
    },
    "evidence_file_hashes": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Mapping of evidence file paths to their SHA-256 hashes"
    },
    "runtime_artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of runtime artifact paths"
    },
    "source_mutation_status": {
      "type": "string",
      "description": "Status of source mutation checks"
    },
    "final_decision": {
      "type": "string",
      "description": "Final decision recorded in the manifest"
    },
    "evidence_manifest_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of the evidence manifest"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
