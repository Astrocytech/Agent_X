{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "model_capability_profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "capability_id", "capability_class",
    "description", "warnings", "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "capability_id": { "type": "string" },
    "capability_class": { "type": "string" },
    "description": { "type": "string" },
    "supported_tasks": { "type": "array", "items": { "type": "string" } },
    "requires_json_output": { "type": "boolean" },
    "requires_output_schema": { "type": "boolean" },
    "max_context_window": { "type": "integer" },
    "writes_source": { "type": "boolean" },
    "runs_tools": { "type": "boolean" },
    "runs_commands": { "type": "boolean" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
