{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "scheduler_retry_policy.schema.json",
  "title": "Scheduler Retry Policy",
  "description": "Defines the retry policy configuration for scheduler task execution within Agent X's Task Queue / Session Scheduler Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "policy_id",
    "max_retries",
    "base_delay_seconds",
    "max_delay_seconds",
    "backoff_multiplier",
    "retryable_statuses",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "policy_id": { "type": "string" },
    "max_retries": { "type": "integer" },
    "base_delay_seconds": { "type": "integer" },
    "max_delay_seconds": { "type": "integer" },
    "backoff_multiplier": { "type": "number" },
    "retryable_statuses": { "type": "array", "items": { "type": "string" } },
    "use_jitter": { "type": "boolean" },
    "timeout_seconds": { "type": "integer" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
