{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DocumentRecord",
  "type": "object",
  "required": ["schema_version", "schema_id", "document_id", "path", "document_type", "authority"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"type": "string", "enum": ["documentation_record.schema.json"]},
    "document_id": {"type": "string"},
    "path": {"type": "string"},
    "title": {"type": "string"},
    "document_type": {"type": "string"},
    "authority": {"type": "string"},
    "component_id": {"type": "string"},
    "layer_id": {"type": "string"},
    "version": {"type": "string"},
    "status": {"type": "string"},
    "sha256": {"type": "string"},
    "last_modified_utc": {"type": "string"},
    "contains_generated_markers": {"type": "boolean"},
    "protected": {"type": "boolean"},
    "links_out": {"type": "array", "items": {"type": "string"}},
    "links_in": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
