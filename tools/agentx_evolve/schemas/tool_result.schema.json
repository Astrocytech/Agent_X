{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "tool_result.schema.json",
  "owner_component": "ToolAdapter",
  "artifact_type": "tool_result",
  "type": "object",
  "required": ["tool_name", "status", "message"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "schema_id": {"type": "string", "const": "tool_result.schema.json"},
    "result_id": {"type": "string"},
    "timestamp": {"type": "string"},
    "tool_name": {"type": "string"},
    "status": {"type": "string", "enum": ["SUCCESS", "PARTIAL", "BLOCKED", "FAILED", "INVALID"]},
    "message": {"type": "string"},
    "data": {"type": "object"},
    "artifact_refs": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
