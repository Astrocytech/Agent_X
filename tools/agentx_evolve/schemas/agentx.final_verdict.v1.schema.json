{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "agentx.final_verdict.v1",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "command",
    "exit_code",
    "run_id",
    "summary",
    "failures",
    "blocked_reasons",
    "validation_status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "agentx.final_verdict.v1"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "BLOCKED"]
    },
    "command": {
      "type": "string"
    },
    "exit_code": {
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "run_id": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "failures": {
      "type": "array",
      "items": {"type": "string"}
    },
    "blocked_reasons": {
      "type": "array",
      "items": {"type": "string"}
    },
    "validation_status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "BLOCKED"]
    }
  }
}
