{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "document_drift_record.schema.json",
  "title": "DocumentDriftRecord",
  "description": "Records a single detected drift between expected and actual documentation state within the Documentation Synchronization Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "drift_id",
    "created_at",
    "document_id",
    "path",
    "drift_type",
    "status"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string", "enum": ["document_drift_record.schema.json"] },
    "drift_id": { "type": "string" },
    "created_at": { "type": "string" },
    "document_id": { "type": "string" },
    "path": { "type": "string" },
    "drift_type": { "type": "string" },
    "status": { "type": "string" },
    "expected": { "type": "object" },
    "actual": { "type": "object" },
    "severity": { "type": "string" },
    "recommended_operation": { "type": "string" },
    "blocked_reason": { "type": "string" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
