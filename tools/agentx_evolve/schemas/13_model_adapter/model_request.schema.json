{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "model_request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "model_request_id", "timestamp",
    "source_component", "caller_role", "task_type", "model_id",
    "provider_id", "prompt", "json_only", "warnings", "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "model_request_id": { "type": "string" },
    "timestamp": { "type": "string" },
    "source_component": { "type": "string" },
    "caller_role": { "type": "string" },
    "task_type": { "type": "string" },
    "model_id": { "type": "string" },
    "provider_id": { "type": "string" },
    "prompt": { "type": "string" },
    "system_prompt": { "type": "string" },
    "json_only": { "type": "boolean" },
    "expected_output_schema_id": { "type": ["string", "null"] },
    "context_budget_tokens": { "type": "integer" },
    "max_output_tokens": { "type": "integer" },
    "temperature": { "type": "number" },
    "original_request_id": { "type": ["string", "null"] },
    "retry_attempt": { "type": "integer" },
    "dry_run": { "type": "boolean" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
