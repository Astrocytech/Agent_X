{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "model_selection_decision.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "decision_id", "timestamp",
    "source_component", "task_type", "decision", "reason", "warnings", "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "decision_id": { "type": "string" },
    "timestamp": { "type": "string" },
    "source_component": { "type": "string" },
    "task_type": { "type": "string" },
    "selected_model_id": { "type": ["string", "null"] },
    "selected_provider_id": { "type": ["string", "null"] },
    "decision": { "type": "string" },
    "reason": { "type": "string" },
    "alternatives": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
