{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "model_provider_profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "provider_id", "provider_type",
    "display_name", "transport_mode", "local_only", "network_allowed",
    "enabled", "warnings", "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "provider_id": { "type": "string" },
    "provider_type": { "type": "string" },
    "display_name": { "type": "string" },
    "transport_mode": { "type": "string" },
    "endpoint_allowlisted": { "type": "boolean" },
    "credential_ref": { "type": ["string", "null"] },
    "default_timeout_seconds": { "type": "integer" },
    "max_retries": { "type": "integer" },
    "local_only": { "type": "boolean" },
    "network_allowed": { "type": "boolean" },
    "hosted_fallback_allowed": { "type": "boolean" },
    "enabled": { "type": "boolean" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
