{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "model_adapter_completion_record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "component_id", "component_name",
    "status", "validated_commit", "validated_at", "review_environment",
    "commands_run", "files_created_or_changed", "schemas_created_or_changed",
    "tests_created_or_changed", "validated_capabilities",
    "implementation_score", "final_decision"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "component_id": { "type": "string" },
    "component_name": { "type": "string" },
    "status": { "type": "string" },
    "validated_commit": { "type": "string" },
    "validated_at": { "type": "string" },
    "review_environment": {
      "type": "object",
      "properties": {
        "os": { "type": "string" },
        "python_version": { "type": "string" },
        "pytest_version": { "type": "string" }
      }
    },
    "canonical_model_subdirectory": { "type": "string" },
    "canonical_runtime_subdirectory": { "type": "string" },
    "canonical_schema_subdirectory": { "type": "string" },
    "canonical_test_subdirectory": { "type": "string" },
    "runtime_artifact_root": { "type": "string" },
    "basis_documents": { "type": "array", "items": { "type": "string" } },
    "commands_run": { "type": "array", "items": { "type": "object" } },
    "files_created_or_changed": { "type": "array", "items": { "type": "string" } },
    "schemas_created_or_changed": { "type": "array", "items": { "type": "string" } },
    "tests_created_or_changed": { "type": "array", "items": { "type": "string" } },
    "validated_capabilities": { "type": "array", "items": { "type": "object" } },
    "evidence_manifest_path": { "type": "string" },
    "evidence_manifest_sha256": { "type": "string" },
    "completion_record_sha256": { "type": "string" },
    "deviation_register": { "type": "array", "items": { "type": "object" } },
    "unresolved_risks": { "type": "array", "items": { "type": "object" } },
    "implementation_score": { "type": "number" },
    "final_decision": { "type": "string" }
  }
}
