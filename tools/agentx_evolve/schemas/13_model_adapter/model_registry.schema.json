{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "model_registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "registry_id", "created_at",
    "source_component", "models", "provider_profiles", "capability_profiles",
    "warnings", "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "registry_id": { "type": "string" },
    "created_at": { "type": "string" },
    "source_component": { "type": "string" },
    "models": { "type": "array", "items": { "$ref": "model_profile.schema.json" } },
    "provider_profiles": { "type": "array", "items": { "$ref": "model_provider_profile.schema.json" } },
    "capability_profiles": { "type": "array", "items": { "$ref": "model_capability_profile.schema.json" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
