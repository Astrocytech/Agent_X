{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "invalid_model_request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "record_id", "timestamp",
    "source_component", "reason", "failure_class", "warnings", "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "record_id": { "type": "string" },
    "timestamp": { "type": "string" },
    "source_component": { "type": "string" },
    "model_id": { "type": ["string", "null"] },
    "caller_role": { "type": ["string", "null"] },
    "reason": { "type": "string" },
    "failure_class": { "type": "string" },
    "safe_request_summary": { "type": "string" },
    "raw_request": { "type": "object" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
