{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "model_response.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "model_response_id", "model_request_id",
    "timestamp", "source_component", "model_id", "provider_id",
    "status", "message", "warnings", "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "model_response_id": { "type": "string" },
    "model_request_id": { "type": "string" },
    "timestamp": { "type": "string" },
    "source_component": { "type": "string" },
    "model_id": { "type": "string" },
    "provider_id": { "type": "string" },
    "status": { "type": "string" },
    "message": { "type": "string" },
    "raw_output": { "type": "string" },
    "json_output": { "type": ["object", "null"] },
    "json_valid": { "type": "boolean" },
    "schema_valid": { "type": "boolean" },
    "prompt_hash": { "type": "string" },
    "output_hash": { "type": "string" },
    "failure_class": { "type": ["string", "null"] },
    "token_count_input": { "type": "integer" },
    "token_count_output": { "type": "integer" },
    "latency_seconds": { "type": "number" },
    "tool_call_suggestions": { "type": "array", "items": { "type": "object" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
