{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "completion_record.schema.json",
  "title": "Completion Record",
  "type": "object",
  "required": ["schema_version", "schema_id", "component_id", "status", "validated_at"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"type": "string", "pattern": "^completion_record\\.schema\\.json$"},
    "component_id": {"type": "string"},
    "component_name": {"type": "string"},
    "status": {"type": "string", "enum": ["COMPLETED", "VALIDATED", "DONE", "NOT DONE"]},
    "validated_commit": {"type": "string"},
    "validated_at": {"type": "string"},
    "canonical_subdirectory": {"type": "string"},
    "basis_documents": {"type": "array", "items": {"type": "string"}},
    "commands_run": {"type": "array", "items": {"type": "object"}},
    "files_created_or_changed": {"type": "array", "items": {"type": "string"}},
    "validated_capabilities": {"type": "array", "items": {"type": "string"}},
    "evidence_artifacts": {"type": "array", "items": {"type": "string"}},
    "evidence_hashes": {"type": "array", "items": {"type": "object"}},
    "deviations_from_contract": {"type": "array", "items": {"type": "string"}},
    "final_decision": {"type": "string", "enum": ["DONE", "NOT DONE"]}
  }
}
