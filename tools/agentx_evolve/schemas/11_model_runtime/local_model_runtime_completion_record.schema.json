{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "local_model_runtime_completion_record.schema.json",
  "title": "Local Model Runtime Completion Record",
  "type": "object",
  "required": ["component_id", "status", "final_decision"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "local_model_runtime_completion_record.schema.json"},
    "component_id": {"const": "AGENTX_LOCAL_MODEL_RUNTIME_PROFILE"},
    "component_name": {"type": "string"},
    "status": {"type": "string"},
    "validated_commit": {"type": "string"},
    "validated_at": {"type": "string"},
    "review_environment": {"type": "object"},
    "canonical_subdirectory": {"type": "string"},
    "canonical_schema_subdirectory": {"type": "string"},
    "canonical_test_subdirectory": {"type": "string"},
    "runtime_artifact_root": {"type": "string"},
    "basis_documents": {"type": "array", "items": {"type": "string"}},
    "commands_run": {"type": "array", "items": {"type": "object"}},
    "files_created_or_changed": {"type": "array", "items": {"type": "string"}},
    "schemas_created_or_changed": {"type": "array", "items": {"type": "string"}},
    "tests_created_or_changed": {"type": "array", "items": {"type": "string"}},
    "validated_capabilities": {"type": "array", "items": {"type": "string"}},
    "model_profiles_verified": {"type": "array", "items": {"type": "string"}},
    "hardware_profiles_verified": {"type": "array", "items": {"type": "string"}},
    "no_load_validation_verified": {"type": "array", "items": {"type": "string"}},
    "runtime_compatibility_verified": {"type": "array", "items": {"type": "string"}},
    "model_locator_safety_verified": {"type": "array", "items": {"type": "string"}},
    "inventory_drift_verified": {"type": "array", "items": {"type": "string"}},
    "quantization_compatibility_verified": {"type": "array", "items": {"type": "string"}},
    "context_window_compatibility_verified": {"type": "array", "items": {"type": "string"}},
    "memory_budget_verified": {"type": "array", "items": {"type": "string"}},
    "policy_integration_verified": {"type": "array", "items": {"type": "string"}},
    "model_adapter_integration_verified": {"type": "array", "items": {"type": "string"}},
    "context_builder_integration_verified": {"type": "array", "items": {"type": "string"}},
    "prompt_contract_integration_verified": {"type": "array", "items": {"type": "string"}},
    "tool_mcp_adapter_integration_verified": {"type": "array", "items": {"type": "string"}},
    "negative_tests_verified": {"type": "array", "items": {"type": "string"}},
    "evidence_manifest_path": {"type": "string"},
    "evidence_manifest_sha256": {"type": "string"},
    "review_report_path": {"type": "string"},
    "review_report_sha256": {"type": "string"},
    "completion_record_sha256": {"type": "string"},
    "deviation_register": {"type": "array", "items": {"type": "object"}},
    "unresolved_risks": {"type": "array", "items": {"type": "object"}},
    "implementation_score": {"type": "number"},
    "final_decision": {"type": "string"}
  }
}
