{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "local_runtime_request_limits.schema.json",
  "title": "Local Runtime Request Limits",
  "type": "object",
  "required": ["max_prompt_tokens", "max_response_tokens", "max_total_context_tokens"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "local_runtime_request_limits.schema.json"},
    "max_prompt_tokens": {"type": "integer", "minimum": 1},
    "max_response_tokens": {"type": "integer", "minimum": 1},
    "max_total_context_tokens": {"type": "integer", "minimum": 1},
    "max_input_bytes": {"type": "integer", "minimum": 0},
    "max_output_bytes": {"type": "integer", "minimum": 0},
    "max_batch_size": {"type": "integer", "minimum": 1},
    "max_concurrent_requests": {"type": "integer", "minimum": 1},
    "reserved_response_tokens": {"type": "integer", "minimum": 0},
    "safety_margin_tokens": {"type": "integer", "minimum": 0},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
