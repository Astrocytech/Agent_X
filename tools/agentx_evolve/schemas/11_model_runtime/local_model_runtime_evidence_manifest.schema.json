{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "local_model_runtime_evidence_manifest.schema.json",
  "title": "Local Model Runtime Evidence Manifest",
  "type": "object",
  "required": ["component_id", "final_decision"],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "local_model_runtime_evidence_manifest.schema.json"},
    "component_id": {"const": "AGENTX_LOCAL_MODEL_RUNTIME_PROFILE"},
    "validated_commit": {"type": "string"},
    "validated_at": {"type": "string"},
    "review_environment": {"type": "object"},
    "commands": {"type": "array", "items": {"type": "object"}},
    "evidence_files": {"type": "array", "items": {"type": "string"}},
    "evidence_file_hashes": {"type": "array", "items": {"type": "object"}},
    "required_artifact_hashes": {"type": "object"},
    "runtime_artifacts": {"type": "array", "items": {"type": "string"}},
    "known_expected_runtime_artifacts": {"type": "array", "items": {"type": "string"}},
    "deviation_register": {"type": "array", "items": {"type": "object"}},
    "source_mutation_status": {"type": "string"},
    "no_load_validation_status": {"type": "string"},
    "deterministic_reproducibility_status": {"type": "string"},
    "bounded_validation_status": {"type": "string"},
    "model_profile_validation_status": {"type": "string"},
    "hardware_profile_validation_status": {"type": "string"},
    "runtime_compatibility_status": {"type": "string"},
    "model_locator_safety_status": {"type": "string"},
    "inventory_drift_status": {"type": "string"},
    "cache_invalidation_status": {"type": "string"},
    "capability_taxonomy_status": {"type": "string"},
    "environment_redaction_status": {"type": "string"},
    "policy_integration_status": {"type": "string"},
    "model_adapter_integration_status": {"type": "string"},
    "context_builder_integration_status": {"type": "string"},
    "prompt_contract_integration_status": {"type": "string"},
    "tool_mcp_integration_status": {"type": "string"},
    "hash_status": {"type": "string"},
    "final_decision": {"type": "string"}
  }
}
