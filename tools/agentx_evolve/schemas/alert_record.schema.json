{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "alert_record.schema.json",
  "title": "Alert Record",
  "description": "Schema for an alert record generated by the Monitoring Observability Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "alert_id",
    "rule_name",
    "severity",
    "message",
    "component",
    "timestamp"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "alert_record.schema.json",
      "description": "Unique schema identifier"
    },
    "alert_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique alert identifier"
    },
    "rule_name": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the alert rule that triggered"
    },
    "severity": {
      "type": "string",
      "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"],
      "description": "Alert severity level"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "description": "Alert message"
    },
    "component": {
      "type": "string",
      "minLength": 1,
      "description": "Component that triggered the alert"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the alert"
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata associated with the alert"
    },
    "acknowledged": {
      "type": "boolean",
      "description": "Whether the alert has been acknowledged"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
