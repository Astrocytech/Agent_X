{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "package_staging_cleanliness_report.schema.json",
  "title": "Package Staging Cleanliness Report",
  "description": "Schema for the package staging cleanliness report",
  "schema_version": "1.0",
  "schema_id": {
    "const": "package_staging_cleanliness_report.schema.json"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "report_id",
    "created_at",
    "source_component",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "package_staging_cleanliness_report.schema.json",
      "description": "Unique schema identifier"
    },
    "report_id": {
      "type": "string",
      "description": "Unique report identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "source_component": {
      "type": "string",
      "description": "Name of the source component"
    },
    "staging_dir": {
      "type": "string",
      "description": "Path to the staging directory"
    },
    "dist_dir": {
      "type": "string",
      "description": "Path to the dist directory"
    },
    "expected_staging_id": {
      "type": "string",
      "description": "Expected staging directory identifier"
    },
    "stale_staging_entries": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Stale entries found in staging directory"
    },
    "stale_dist_entries": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Stale entries found in dist directory"
    },
    "issues": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Issues found during cleanliness check"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL"],
      "description": "Cleanliness check status"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
