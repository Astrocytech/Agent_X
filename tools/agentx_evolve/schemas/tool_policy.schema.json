{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "tool_policy.schema.json",
  "owner_component": "PolicyCapabilityRegistry",
  "artifact_type": "tool_policy",
  "type": "object",
  "required": [
    "schema_version",
    "schema_id",
    "policy_id",
    "timestamp",
    "source_component",
    "tools",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "schema_id": {
      "type": "string",
      "const": "tool_policy.schema.json"
    },
    "policy_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "source_component": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ToolEntry"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "ToolEntry": {
      "type": "object",
      "properties": {
        "tool_name": {
          "type": "string"
        },
        "tool_category": {
          "type": "string"
        },
        "trust_tier": {
          "type": "string"
        },
        "requested_effects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requires_governance": {
          "type": "boolean"
        },
        "requires_human_approval": {
          "type": "boolean"
        },
        "requires_sandbox": {
          "type": "boolean"
        },
        "requires_risk_review": {
          "type": "boolean"
        },
        "writes_source": {
          "type": "boolean"
        },
        "writes_runtime": {
          "type": "boolean"
        },
        "executes_command": {
          "type": "boolean"
        },
        "uses_network": {
          "type": "boolean"
        },
        "uses_model": {
          "type": "boolean"
        },
        "allowlisted": {
          "type": "boolean"
        },
        "blocked": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
