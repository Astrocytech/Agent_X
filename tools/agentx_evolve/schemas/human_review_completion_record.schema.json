{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "human_review_completion_record.schema.json",
  "title": "Human Review Completion Record",
  "description": "Records the completion summary and verification status of the Human Review / Approval Interface implementation within Agent X's HumanReview Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "component_id",
    "component_name",
    "status",
    "validated_commit",
    "validated_at",
    "canonical_subdirectory",
    "runtime_artifact_root",
    "basis_documents",
    "commands_run",
    "files_created_or_changed",
    "schemas_created_or_changed",
    "tests_created_or_changed",
    "evidence_manifest_path",
    "evidence_manifest_sha256",
    "completion_record_sha256",
    "final_decision",
    "deviations_from_contract",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "component_id": { "type": "string" },
    "component_name": { "type": "string" },
    "status": { "type": "string" },
    "validated_commit": { "type": "string" },
    "validated_at": { "type": "string" },
    "canonical_subdirectory": { "type": "string" },
    "runtime_artifact_root": { "type": "string" },
    "basis_documents": { "type": "array", "items": { "type": "string" } },
    "commands_run": { "type": "array", "items": { "type": "object" } },
    "files_created_or_changed": { "type": "array", "items": { "type": "string" } },
    "schemas_created_or_changed": { "type": "array", "items": { "type": "string" } },
    "tests_created_or_changed": { "type": "array", "items": { "type": "string" } },
    "evidence_manifest_path": { "type": "string" },
    "evidence_manifest_sha256": { "type": "string" },
    "completion_record_sha256": { "type": "string" },
    "final_decision": { "type": "string" },
    "deviations_from_contract": { "type": "array", "items": { "type": "object" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
