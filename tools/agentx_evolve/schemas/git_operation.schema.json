    },
    "op_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "operation": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "repo_path": {
      "type": "string"
    },
    "op_type": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
