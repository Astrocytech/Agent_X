{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FinalAcceptanceLayerRegistry",
  "type": "object",
  "required": [
    "schema_version", "schema_id", "source_component",
    "acceptance_mode", "layers"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"enum": ["final_acceptance_layer_registry.schema.json"]},
    "source_component": {"type": "string"},
    "reviewed_commit": {"type": ["string", "null"]},
    "reviewed_branch": {"type": ["string", "null"]},
    "created_at": {"type": "string"},
    "acceptance_mode": {"type": "string"},
    "bootstrap_self": {"type": "boolean"},
    "layers": {
      "type": "array",
      "items": {"$ref": "final_acceptance_layer.schema.json"}
    },
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
