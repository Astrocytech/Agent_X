    },
    "timestamp": {
      "type": "string"
    },
    "tool_name": {
      "type": "string"
    },
    "operation": {
      "type": "string"
    },
    "decision": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "matched_rule_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "matched_rule_effect": {
      "type": [
        "string",
        "null"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
