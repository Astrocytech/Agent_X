{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "health_report.schema.json",
  "title": "Health Report",
  "description": "Schema for an aggregated health report containing multiple health checks within the Monitoring Observability Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "report_id",
    "overall_status",
    "checks",
    "timestamp"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "health_report.schema.json",
      "description": "Unique schema identifier"
    },
    "report_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique health report identifier"
    },
    "overall_status": {
      "type": "string",
      "enum": ["HEALTHY", "DEGRADED", "UNHEALTHY", "UNKNOWN"],
      "description": "Overall aggregated health status"
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "health_check.schema.json" },
      "description": "List of individual health check results"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the report"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
