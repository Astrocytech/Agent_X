{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "runtime_artifact_exclusion_report.schema.json",
  "title": "Runtime Artifact Exclusion Report",
  "description": "Schema for the runtime artifact exclusion report",
  "schema_version": "1.0",
  "schema_id": {
    "const": "runtime_artifact_exclusion_report.schema.json"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "report_id",
    "created_at",
    "source_component",
    "scanned_count",
    "excluded_count",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "runtime_artifact_exclusion_report.schema.json",
      "description": "Unique schema identifier"
    },
    "report_id": {
      "type": "string",
      "description": "Unique report identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "source_component": {
      "type": "string",
      "description": "Name of the source component"
    },
    "scanned_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of files scanned"
    },
    "excluded_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of files excluded"
    },
    "excluded_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string", "description": "Path to the excluded file" },
          "reason": { "type": "string", "description": "Reason for exclusion" }
        }
      },
      "description": "List of excluded files"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "PARTIAL", "FAIL", "BLOCKED", "NOT CHECKED", "NOT RUN", "NOT APPLICABLE", "DEFERRED SAFELY"],
      "description": "Exclusion status"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
