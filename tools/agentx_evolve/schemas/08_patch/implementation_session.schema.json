{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "implementation_session.schema.json",
  "owner_component": "GovernedPatchExecution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "session_id",
    "timestamp",
    "source_component",
    "lifecycle_state",
    "status",
    "final_decision",
    "target_paths",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "session_id": { "type": "string" },
    "timestamp": { "type": "string" },
    "source_component": { "type": "string" },
    "lifecycle_state": { "type": "string" },
    "status": { "type": "string" },
    "final_decision": { "type": "string" },
    "target_paths": { "type": "array", "items": { "type": "string" } },
    "proposal_id": { "type": "string" },
    "governance_decision_id": { "type": "string" },
    "policy_decision_id": { "type": "string" },
    "sandbox_decision_ids": { "type": "array", "items": { "type": "string" } },
    "dry_run_id": { "type": "string" },
    "rollback_snapshot_id": { "type": "string" },
    "patch_application_id": { "type": "string" },
    "source_inventory_before_id": { "type": "string" },
    "source_inventory_after_id": { "type": "string" },
    "source_change_guard_id": { "type": "string" },
    "validation_result_id": { "type": "string" },
    "rollback_record_id": { "type": "string" },
    "changed_paths": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
