{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "document_index_record.schema.json",
  "title": "DocumentIndexRecord",
  "description": "Represents a generated index of documentation files within the Documentation Synchronization Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "index_id",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string", "enum": ["document_index_record.schema.json"] },
    "index_id": { "type": "string" },
    "created_at": { "type": "string" },
    "entries": { "type": "array", "items": { "type": "object" } },
    "summary": { "type": "object" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
