{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "schema_id": "prompt_registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "registry_id", "registry_version",
    "created_at", "contracts", "versions"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "prompt_registry.schema.json"},
    "registry_id": {"type": "string"},
    "registry_version": {"type": "string"},
    "created_at": {"type": "string"},
    "source_component": {"type": "string"},
    "contracts": {"type": "array", "items": {"$ref": "prompt_contract.schema.json"}},
    "versions": {"type": "array", "items": {"$ref": "prompt_version.schema.json"}},
    "active_bindings": {"type": "object"},
    "registry_sha256": {"type": "string"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
