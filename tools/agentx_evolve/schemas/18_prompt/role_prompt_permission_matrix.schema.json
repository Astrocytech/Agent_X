{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "schema_id": "role_prompt_permission_matrix.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "matrix_id", "roles",
    "version", "created_at"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "role_prompt_permission_matrix.schema.json"},
    "matrix_id": {"type": "string", "description": "Unique identifier for the matrix"},
    "roles": {"type": "object", "description": "Map of role names to permission sets"},
    "default_permissions": {"type": "array", "items": {"type": "string"}, "description": "Default permissions for unmapped roles"},
    "version": {"type": "string"},
    "created_at": {"type": "string"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
