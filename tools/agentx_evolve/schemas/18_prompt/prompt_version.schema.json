{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "schema_id": "prompt_version.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "prompt_version_id", "prompt_contract_id",
    "version", "created_at", "created_by", "status", "prompt_body",
    "prompt_body_sha256", "change_summary"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "prompt_version.schema.json"},
    "prompt_version_id": {"type": "string"},
    "prompt_contract_id": {"type": "string"},
    "version": {"type": "string"},
    "created_at": {"type": "string"},
    "created_by": {"type": "string"},
    "status": {"type": "string", "enum": ["DRAFT", "ACTIVE", "DEPRECATED", "RETIRED", "BLOCKED"]},
    "prompt_body": {"type": "string"},
    "prompt_body_sha256": {"type": "string"},
    "change_summary": {"type": "string"},
    "breaking_change": {"type": "boolean"},
    "supersedes_version_id": {"type": "string"},
    "migration_id": {"type": "string"},
    "provenance_id": {"type": "string"},
    "audit_refs": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
