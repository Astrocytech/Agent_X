{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "backup_catalog.schema.json",
  "title": "Backup Catalog",
  "description": "Central registry of all snapshots for a project, tracking verified, protected, deleted, and stale backups.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "catalog_id",
    "updated_at",
    "project_id",
    "repo_root_fingerprint",
    "backup_format_version",
    "snapshots",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "catalog_id": { "type": "string" },
    "updated_at": { "type": "string", "format": "date-time" },
    "project_id": { "type": "string" },
    "repo_root_fingerprint": { "type": "string" },
    "backup_format_version": { "type": "string" },
    "snapshots": { "type": "array", "items": { "type": "object" } },
    "latest_verified_backup_id": { "type": ["string", "null"] },
    "protected_backup_ids": { "type": "array", "items": { "type": "string" } },
    "deleted_backup_ids": { "type": "array", "items": { "type": "string" } },
    "stale_staging_paths": { "type": "array", "items": { "type": "string" } },
    "catalog_sha256": { "type": ["string", "null"] },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
