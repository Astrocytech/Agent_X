{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "backup_manifest.schema.json",
  "title": "Backup Manifest",
  "description": "Records the metadata, scope, and verification context of a single backup operation within Agent X's Backup/Disaster Recovery Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "backup_id",
    "created_at",
    "source_component",
    "repo_root",
    "snapshot_path",
    "file_records",
    "status",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "backup_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "source_component": { "const": "BackupDisasterRecovery" },
    "repo_root": { "type": "string" },
    "git_commit": { "type": ["string", "null"] },
    "git_branch": { "type": ["string", "null"] },
    "git_status_summary": { "type": "string", "enum": ["CLEAN", "DIRTY", "UNKNOWN"] },
    "backup_scope": { "type": "array", "items": { "type": "string" } },
    "snapshot_path": { "type": "string" },
    "snapshot_record": { "type": "object" },
    "file_records": { "type": "array", "items": { "type": "object" } },
    "excluded_records": { "type": "array", "items": { "type": "object" } },
    "manifest_sha256": { "type": ["string", "null"] },
    "snapshot_sha256": { "type": ["string", "null"] },
    "policy_decision_id": { "type": ["string", "null"] },
    "sandbox_decision_ids": { "type": "array", "items": { "type": "string" } },
    "promotion_refs": { "type": "array", "items": { "type": "string" } },
    "monitoring_refs": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["CREATED", "STAGED", "VERIFIED", "FAILED", "INVALID", "BLOCKED"] },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
