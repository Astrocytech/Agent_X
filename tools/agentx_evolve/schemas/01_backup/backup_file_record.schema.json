{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "backup_file_record.schema.json",
  "title": "Backup File Record",
  "description": "Describes a single file or directory within a backup snapshot, including its paths, size, hash, and inclusion status.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "relative_path",
    "original_path",
    "backup_path",
    "file_size_bytes",
    "included",
    "path_type",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "relative_path": { "type": "string" },
    "original_path": { "type": "string" },
    "backup_path": { "type": "string" },
    "file_size_bytes": { "type": "integer" },
    "sha256": { "type": ["string", "null"] },
    "included": { "type": "boolean" },
    "exclusion_reason": { "type": ["string", "null"] },
    "path_type": { "type": "string", "enum": ["file", "directory", "symlink", "other"] },
    "mode": { "type": ["string", "null"] },
    "mtime_ns": { "type": ["integer", "null"] },
    "symlink_target": { "type": ["string", "null"] },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
