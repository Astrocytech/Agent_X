{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "restore_preflight_record.schema.json",
  "title": "Restore Preflight Record",
  "description": "Captures the results of preflight checks performed before executing a restore to ensure compatibility and safety.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "preflight_id",
    "restore_request_id",
    "backup_id",
    "checked_at",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "preflight_id": { "type": "string" },
    "restore_request_id": { "type": "string" },
    "backup_id": { "type": "string" },
    "checked_at": { "type": "string", "format": "date-time" },
    "backup_format_compatible": { "type": "boolean" },
    "project_identity_match": { "type": "boolean" },
    "schema_versions_supported": { "type": "boolean" },
    "verified_backup": { "type": "boolean" },
    "target_paths_sandboxed": { "type": "boolean" },
    "git_state_safe": { "type": "boolean" },
    "promotion_gate_passed": { "type": "boolean" },
    "destructive_actions_detected": { "type": "array", "items": { "type": "string" } },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
