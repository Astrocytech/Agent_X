{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "disaster_recovery_plan.schema.json",
  "title": "Disaster Recovery Plan",
  "description": "Defines the step-by-step plan for recovering from a disaster, including recovery, validation, and rollback steps.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "disaster_recovery_plan_id",
    "created_at",
    "trigger",
    "recovery_steps",
    "validation_steps",
    "rollback_steps",
    "required_approvals",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "disaster_recovery_plan_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "trigger": { "type": "string" },
    "selected_backup_id": { "type": ["string", "null"] },
    "recovery_steps": { "type": "array", "items": { "type": "string" } },
    "validation_steps": { "type": "array", "items": { "type": "string" } },
    "rollback_steps": { "type": "array", "items": { "type": "string" } },
    "required_approvals": { "type": "array", "items": { "type": "string" } },
    "rejected_backup_ids": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
