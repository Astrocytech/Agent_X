{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "backup_policy.schema.json",
  "title": "Backup Policy",
  "description": "Defines the security and operational policy governing backup and restore operations within Agent X's Backup/Disaster Recovery Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "policy_id",
    "allowed_backup_roots",
    "allowed_restore_roots",
    "excluded_paths",
    "excluded_globs",
    "excluded_secret_patterns",
    "require_git_status",
    "require_hashes",
    "require_manifest_validation",
    "require_restore_dry_run",
    "allow_source_backup",
    "allow_source_restore",
    "allow_runtime_restore",
    "allow_release_restore",
    "allow_secret_backup_plaintext",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "policy_id": { "type": "string" },
    "allowed_backup_roots": { "type": "array", "items": { "type": "string" } },
    "allowed_restore_roots": { "type": "array", "items": { "type": "string" } },
    "excluded_paths": { "type": "array", "items": { "type": "string" } },
    "excluded_globs": { "type": "array", "items": { "type": "string" } },
    "excluded_secret_patterns": { "type": "array", "items": { "type": "string" } },
    "require_git_status": { "type": "boolean" },
    "require_hashes": { "type": "boolean" },
    "require_manifest_validation": { "type": "boolean" },
    "require_restore_dry_run": { "type": "boolean" },
    "allow_source_backup": { "type": "boolean" },
    "allow_source_restore": { "type": "boolean" },
    "allow_runtime_restore": { "type": "boolean" },
    "allow_release_restore": { "type": "boolean" },
    "allow_secret_backup_plaintext": { "type": "boolean" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
