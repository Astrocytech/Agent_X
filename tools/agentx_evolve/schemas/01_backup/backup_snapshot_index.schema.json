{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "backup_snapshot_index.schema.json",
  "title": "Backup Snapshot Index",
  "description": "Indexes all file records within a snapshot, capturing their paths, hashes, and metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "snapshot_index_id",
    "backup_id",
    "created_at",
    "snapshot_path",
    "file_records",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "snapshot_index_id": { "type": "string" },
    "backup_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "snapshot_path": { "type": "string" },
    "file_records": { "type": "array", "items": { "type": "object" } },
    "snapshot_sha256": { "type": ["string", "null"] },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
