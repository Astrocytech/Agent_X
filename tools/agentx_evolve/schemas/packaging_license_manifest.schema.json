{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "packaging_license_manifest.schema.json",
  "title": "Packaging License Manifest",
  "description": "Schema for license manifest per CONTRACT section 23.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "license_manifest_id",
    "created_at",
    "source_component",
    "source_commit",
    "package_name",
    "package_version",
    "declared_project_license",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Schema version"
    },
    "schema_id": {
      "type": "string",
      "const": "packaging_license_manifest.schema.json",
      "description": "Unique schema identifier"
    },
    "license_manifest_id": {
      "type": "string",
      "description": "Unique license manifest identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "source_component": {
      "type": "string",
      "const": "PackagingDistribution",
      "description": "Name of the source component"
    },
    "source_commit": {
      "type": "string",
      "description": "Git commit hash of the source"
    },
    "package_name": {
      "type": "string",
      "description": "Name of the package"
    },
    "package_version": {
      "type": "string",
      "description": "Version of the package"
    },
    "declared_project_license": {
      "type": ["string", "null"],
      "description": "Declared project license identifier"
    },
    "dependency_license_metadata": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "description": "Dependency name" },
          "version": { "type": "string", "description": "Dependency version" },
          "license": { "type": "string", "description": "License identifier" }
        }
      },
      "description": "License metadata for dependencies"
    },
    "unknown_licenses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "description": "Dependency with unknown license" },
          "version": { "type": "string", "description": "Version" }
        }
      },
      "description": "Dependencies with unknown licenses"
    },
    "forbidden_license_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "description": "Dependency with forbidden license" },
          "license": { "type": "string", "description": "Forbidden license identifier" }
        }
      },
      "description": "Dependencies with forbidden licenses"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "PARTIAL", "FAIL", "DEFERRED SAFELY"],
      "description": "License manifest status"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Warning messages"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Error messages"
    }
  }
}
