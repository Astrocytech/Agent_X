{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "failure_record.schema.json",
  "owner_component": "FailureRecovery",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "failure_id",
    "timestamp",
    "source_component",
    "source_layer",
    "failure_class",
    "severity",
    "message",
    "details",
    "requires_recovery",
    "requires_safe_mode",
    "requires_human_review",
    "retryable",
    "rollback_required",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_id": { "type": "string" },
    "failure_id": { "type": "string" },
    "timestamp": { "type": "string" },
    "source_component": { "type": "string" },
    "source_layer": { "type": "string" },
    "session_id": { "type": "string" },
    "operation": { "type": "string" },
    "failure_class": { "type": "string" },
    "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "message": { "type": "string" },
    "details": { "type": "object" },
    "input_artifact_refs": { "type": "array", "items": { "type": "string" } },
    "related_artifact_refs": { "type": "array", "items": { "type": "string" } },
    "requires_recovery": { "type": "boolean" },
    "requires_safe_mode": { "type": "boolean" },
    "requires_human_review": { "type": "boolean" },
    "retryable": { "type": "boolean" },
    "rollback_required": { "type": "boolean" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
