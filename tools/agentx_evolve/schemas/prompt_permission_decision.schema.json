{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "schema_id": "prompt_permission_decision.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_id", "decision_id", "timestamp",
    "source_component", "prompt_contract_id", "caller_role", "task_type",
    "decision", "reason"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "prompt_permission_decision.schema.json"},
    "decision_id": {"type": "string"},
    "timestamp": {"type": "string"},
    "source_component": {"type": "string"},
    "prompt_contract_id": {"type": "string"},
    "prompt_version_id": {"type": "string"},
    "caller_role": {"type": "string"},
    "task_type": {"type": "string"},
    "model_profile_id": {"type": "string"},
    "decision": {"type": "string", "enum": ["ALLOW", "BLOCK", "NEEDS_APPROVAL", "NEEDS_GOVERNANCE", "NEEDS_MIGRATION"]},
    "reason": {"type": "string"},
    "missing_checks": {"type": "array", "items": {"type": "string"}},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
