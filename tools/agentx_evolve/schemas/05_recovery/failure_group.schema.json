{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "failure_group.schema.json",
  "title": "Failure Group",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "group_id",
    "failure_type",
    "count",
    "first_seen",
    "last_seen"
  ],
  "properties": {
    "group_id": { "type": "string", "description": "Unique identifier for the failure group" },
    "failure_type": { "type": "string", "description": "Type or class of failure" },
    "count": { "type": "integer", "minimum": 0, "description": "Number of occurrences in this group" },
    "first_seen": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp of first occurrence" },
    "last_seen": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp of last occurrence" },
    "severity": { "type": "string", "description": "Severity level of the failure" },
    "source_component": { "type": "string", "description": "Component that generated the failure" },
    "resolved": { "type": "boolean", "description": "Whether the failure group has been resolved" },
    "resolution": { "type": "string", "description": "Resolution notes" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
