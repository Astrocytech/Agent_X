{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentx.example/schemas/inverse_science_evidence_manifest",
  "title": "Inverse Science Evidence Manifest",
  "type": "object",
  "required": [
    "manifest_id",
    "plan_id",
    "schema_version",
    "artifacts",
    "event_log_path",
    "created_at_utc"
  ],
  "properties": {
    "manifest_id": {
      "type": "string",
      "pattern": "^INVSCI-MANIFEST-[A-Z0-9-]+$"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^INVSCI-PLAN-[A-Z0-9-]+$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "artifact_type", "sha256", "schema_id"],
        "properties": {
          "path": { "type": "string" },
          "artifact_type": {
            "type": "string",
            "enum": ["plan", "candidate", "ranking", "governance", "observation", "evidence_ledger", "negative_knowledge", "best_known_solution", "event_log", "final_report"]
          },
          "sha256": { "type": "string" },
          "schema_id": { "type": "string" }
        },
        "additionalProperties": true
      },
      "minItems": 1
    },
    "event_log_path": {
      "type": "string"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
