{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentx-init/schemas/repository_fingerprint.schema.json",
  "title": "Repository Fingerprint Schema",
  "type": "object",
  "properties": {
    "schema_version": {"type": "string"},
    "repo_root": {"type": "string"},
    "scanner_version": {"type": "string"},
    "total_files": {"type": "integer", "minimum": 0},
    "total_directories": {"type": "integer", "minimum": 0},
    "file_digest_manifest_hash": {"type": "string"},
    "repository_hash": {"type": "string"},
    "technology_summary": {"type": "object"},
    "layer_summary": {"type": "object"},
    "protected_path_summary": {"type": "object"}
  },
  "required": ["schema_version", "repo_root", "total_files", "repository_hash"]
}
