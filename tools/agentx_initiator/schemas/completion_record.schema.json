{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentx-init/schemas/completion_record.schema.json",
  "title": "Completion Record Schema",
  "description": "Common implementation-completion record shared across all components",
  "type": "object",
  "properties": {
    "unit_id": {"type": "string"},
    "summary": {"type": "string"},
    "evidence_total": {"type": "integer", "minimum": 0},
    "evidence_passed": {"type": "integer", "minimum": 0},
    "all_evidence_passed": {"type": "boolean"},
    "status": {"type": "string", "enum": ["no_evidence", "completed", "partial"]}
  },
  "required": ["unit_id", "summary", "evidence_total", "evidence_passed", "all_evidence_passed", "status"]
}
