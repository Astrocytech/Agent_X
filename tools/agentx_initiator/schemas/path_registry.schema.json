{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentx-init/schemas/path_registry.schema.json",
  "title": "Path Registry Schema",
  "description": "Registry of runtime paths used by Config / Paths component",
  "type": "object",
  "properties": {
    "repo_root": {"type": "string"},
    "state_dir": {"type": "string"},
    "config_file": {"type": "string"},
    "memory_dir": {"type": "string"},
    "reports_dir": {"type": "string"},
    "snapshots_dir": {"type": "string"},
    "graph_dir": {"type": "string"}
  },
  "required": ["repo_root", "state_dir"]
}
