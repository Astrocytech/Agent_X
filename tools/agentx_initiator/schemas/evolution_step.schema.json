{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "evolution_step.schema.json",
  "owner_component": "EvolutionPlanner",
  "artifact_type": "evolution_step",
  "type": "object",
  "required": ["schema_version", "step_id", "priority", "category", "action", "detail", "dependencies", "status"],
  "properties": {
    "schema_version": {"type": "string"},
    "step_id": {"type": "string"},
    "priority": {"type": "string", "enum": ["P0", "P1", "P2", "P3"]},
    "category": {"type": "string", "enum": ["GOVERNANCE", "STRUCTURE", "VALIDATION", "TESTING", "SCHEMA", "SPECIALIZATION", "INTEGRATION", "UNKNOWN"]},
    "action": {"type": "string"},
    "detail": {"type": "string"},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "status": {"type": "string"}
  },
  "additionalProperties": false
}
