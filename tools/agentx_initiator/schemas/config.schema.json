{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentx-init/schemas/config.schema.json",
  "title": "ConfigRecord Schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version identifier",
      "default": "1.0"
    },
    "config_version": {
      "type": "string",
      "description": "Configuration version identifier",
      "default": "1.0.0"
    },
    "default_mode": {
      "type": "string",
      "enum": ["read_only", "advisory", "full"],
      "description": "Default operational mode",
      "default": "read_only"
    },
    "runtime_root": {
      "type": "string",
      "description": "Runtime state directory path",
      "default": ".agentx-init"
    },
    "scan": {
      "type": "object",
      "description": "Repository scanning configuration",
      "properties": {
        "include_hidden": {"type": "boolean", "default": false},
        "max_file_size_mb": {"type": "integer", "default": 5, "minimum": 1},
        "ignore_dirs": {
          "type": "array",
          "items": {"type": "string"},
          "default": [".git", "__pycache__", ".venv", "node_modules", ".agentx-init"]
        }
      },
      "additionalProperties": false
    },
    "feature_flags": {
      "type": "object",
      "description": "Feature flags for later-milestone components",
      "properties": {
        "governance_engine_active": {"type": "boolean", "default": false},
        "risk_engine_active": {"type": "boolean", "default": false},
        "planner_active": {"type": "boolean", "default": false},
        "proposal_generator_active": {"type": "boolean", "default": false},
        "validation_runner_active": {"type": "boolean", "default": false},
        "knowledge_graph_active": {"type": "boolean", "default": false}
      },
      "additionalProperties": false
    }
  },
  "required": ["schema_version", "config_version", "default_mode", "runtime_root", "scan", "feature_flags"],
  "additionalProperties": false
}
