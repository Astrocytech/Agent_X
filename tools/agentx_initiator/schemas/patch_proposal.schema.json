{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0",
  "schema_id": "patch_proposal.schema.json",
  "owner_component": "PatchProposalGenerator",
  "artifact_type": "patch_proposal",
  "type": "object",
  "required": ["schema_version", "proposal_id", "title", "task", "risk_level", "allowed", "reason", "affected_layers", "affected_files", "description", "non_mutating", "generated_at"],
  "properties": {
    "schema_version": {"type": "string"},
    "proposal_id": {"type": "string"},
    "title": {"type": "string"},
    "task": {"type": "string"},
    "risk_level": {"type": "string"},
    "allowed": {"type": "boolean"},
    "reason": {"type": "string"},
    "affected_layers": {"type": "array", "items": {"type": "string"}},
    "affected_files": {"type": "array", "items": {"type": "string"}},
    "description": {"type": "string"},
    "non_mutating": {"type": "boolean"},
    "generated_at": {"type": "string"}
  },
  "additionalProperties": false
}
