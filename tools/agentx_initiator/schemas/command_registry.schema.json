{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentx-init/schemas/command_registry.schema.json",
  "title": "Command Registry Schema",
  "type": "object",
  "properties": {
    "schema_version": {"type": "string"},
    "command": {"type": "string"},
    "category": {"type": "string", "enum": ["HELP", "SCAN", "STATUS", "RESERVED", "UNKNOWN"]},
    "description": {"type": "string"},
    "handler": {"type": "string"},
    "arguments": {"type": "object"},
    "requested_effect": {"type": "string"},
    "requires_governance": {"type": "boolean"},
    "writes_artifacts": {"type": "boolean"},
    "allowed_output_formats": {"type": "array", "items": {"type": "string"}}
  },
  "required": ["schema_version", "command", "category", "handler"]
}
