{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Astrocytech/Agent_X/L1/eqc/schemas/eqc-manifest.schema.json",
  "title": "EQC Manifest",
  "description": "Schema for EQC manifest documents",
  "type": "object",
  "required": ["manifest_version", "portfolio_id", "procedures", "operators"],
  "properties": {
    "manifest_version": {"type": "string"},
    "portfolio_id": {"type": "string"},
    "procedures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["procedure_id", "path", "operators"],
        "properties": {
          "procedure_id": {"type": "string"},
          "path": {"type": "string"},
          "operators": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "operators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path", "category", "purity"],
        "properties": {
          "name": {"type": "string"},
          "path": {"type": "string"},
          "category": {"type": "string"},
          "purity": {"type": "string"}
        }
      }
    }
  }
}
