{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Astrocytech/Agent_X/L1/ecosystem/ecosystem-schemas/ecosystem-validation-output.schema.json",
  "title": "Ecosystem Validation Output",
  "description": "Schema for L1 ecosystem validation output",
  "type": "object",
  "required": ["validation_id", "status", "checks"],
  "properties": {
    "validation_id": {"type": "string"},
    "status": {"type": "string", "enum": ["pass", "fail", "warn"]},
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "status"],
        "properties": {
          "check_id": {"type": "string"},
          "status": {"type": "string"}
        }
      }
    }
  }
}
