{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Clean Replay Report",
  "type": "object",
  "required": [
    "replay_id",
    "source_commit",
    "replay_directory",
    "commands",
    "verdict"
  ],
  "properties": {
    "replay_id": {
      "type": "string"
    },
    "source_commit": {
      "type": "string"
    },
    "replay_directory": {
      "type": "string"
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL",
        "BLOCKED"
      ]
    },
    "differences": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at_utc": {
      "type": "string"
    }
  }
}