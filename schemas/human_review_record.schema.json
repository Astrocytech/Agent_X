{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Human Review Record",
  "type": "object",
  "required": [
    "review_id",
    "artifact_path",
    "reviewer",
    "decision",
    "timestamp_utc"
  ],
  "properties": {
    "review_id": {
      "type": "string"
    },
    "artifact_path": {
      "type": "string"
    },
    "reviewer": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "APPROVED",
        "REJECTED",
        "CHANGES_REQUESTED",
        "APPROVED_WITH_LIMITS"
      ]
    },
    "timestamp_utc": {
      "type": "string"
    },
    "comments": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limits": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Constraints or restrictions attached to the review decision"
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "condition": { "type": "string" },
          "status": { "type": "string", "enum": ["MET", "UNMET", "WAIVED"] }
        }
      },
      "description": "Preconditions that must be satisfied for approval"
    }
  }
}