{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Human Review Record",
  "type": "object",
  "required": [
    "review_id",
    "artifact_path",
    "reviewer",
    "decision",
    "timestamp_utc"
  ],
  "properties": {
    "review_id": {
      "type": "string"
    },
    "artifact_path": {
      "type": "string"
    },
    "reviewer": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "APPROVED",
        "REJECTED",
        "CHANGES_REQUESTED"
      ]
    },
    "timestamp_utc": {
      "type": "string"
    },
    "comments": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}