{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Final Claim Validation",
  "type": "object",
  "required": [
    "validation_id",
    "claims",
    "verdict"
  ],
  "properties": {
    "validation_id": {
      "type": "string"
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": {
            "type": "string"
          },
          "allowed": {
            "type": "boolean"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "created_at_utc": {
      "type": "string"
    }
  }
}