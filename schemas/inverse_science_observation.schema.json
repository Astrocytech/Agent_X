{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Inverse Science Observation",
  "type": "object",
  "required": [
    "observation_id",
    "candidate_id",
    "evidence_class",
    "observation",
    "created_at_utc"
  ],
  "properties": {
    "observation_id": {
      "type": "string"
    },
    "candidate_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "evidence_class": {
      "type": "string",
      "enum": [
        "CONFIRMED",
        "REFUTED",
        "INCONCLUSIVE"
      ]
    },
    "observation": {
      "type": "string"
    },
    "created_at_utc": {
      "type": "string"
    }
  }
}