{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Inverse Science Plan",
  "type": "object",
  "required": [
    "plan_id",
    "target_capability",
    "hard_constraints",
    "soft_preferences",
    "allowed_inputs",
    "forbidden_inputs",
    "created_at_utc"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "target_capability": {
      "type": "string"
    },
    "hard_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "soft_preferences": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "identifiability_assessment": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "COMPLETED",
        "REFRA MED"
      ]
    },
    "created_at_utc": {
      "type": "string"
    }
  }
}