{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BenchmarkResult",
  "type": "object",
  "required": ["run_id", "phase", "timestamp_utc", "cases", "summary"],
  "properties": {
    "run_id": {"type": "string"},
    "phase": {"type": "string"},
    "timestamp_utc": {"type": "string", "format": "date-time"},
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "verdict"],
        "properties": {
          "case_id": {"type": "string"},
          "verdict": {"type": "string", "enum": ["PASS", "FAIL", "BLOCKED", "UNKNOWN", "NOT_APPLICABLE"]},
          "duration_ms": {"type": "integer"},
          "error": {"type": "string"}
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total", "pass", "fail", "blocked"],
      "properties": {
        "total": {"type": "integer"},
        "pass": {"type": "integer"},
        "fail": {"type": "integer"},
        "blocked": {"type": "integer"},
        "unknown": {"type": "integer"},
        "not_applicable": {"type": "integer"}
      }
    }
  }
}
