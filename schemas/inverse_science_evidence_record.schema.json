{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Inverse Science Evidence Record",
  "type": "object",
  "required": [
    "evidence_id",
    "plan_id",
    "records",
    "created_at_utc"
  ],
  "properties": {
    "evidence_id": {
      "type": "string"
    },
    "plan_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "created_at_utc": {
      "type": "string"
    }
  }
}