{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Inverse Science Governance Decision",
  "type": "object",
  "required": [
    "decision_id",
    "candidate_id",
    "decision",
    "created_at_utc"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "candidate_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "ALLOW",
        "ALLOW_WITH_LIMITS",
        "REJECT",
        "REQUIRE_REFRAME"
      ]
    },
    "limits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason": {
      "type": "string"
    },
    "created_at_utc": {
      "type": "string"
    }
  }
}