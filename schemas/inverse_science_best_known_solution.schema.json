{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Inverse Science Best Known Solution",
  "type": "object",
  "required": [
    "solution_id",
    "plan_id",
    "description",
    "evidence_refs",
    "claim_disclaimer",
    "created_at_utc"
  ],
  "properties": {
    "solution_id": {
      "type": "string"
    },
    "plan_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claim_disclaimer": {
      "type": "string"
    },
    "created_at_utc": {
      "type": "string"
    }
  }
}