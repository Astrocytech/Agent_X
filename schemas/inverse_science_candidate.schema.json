{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Inverse Science Candidate",
  "type": "object",
  "required": [
    "candidate_id",
    "plan_id",
    "description",
    "rank",
    "created_at_utc"
  ],
  "properties": {
    "candidate_id": {
      "type": "string"
    },
    "plan_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "rank": {
      "type": "integer"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at_utc": {
      "type": "string"
    }
  }
}